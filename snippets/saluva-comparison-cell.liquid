{%- comment -%}
  MISOJI — Celda de tabla comparativa
  Params:
    value: 'yes' | 'no' | 'text'
    text:  texto a mostrar cuando value == 'text'
{%- endcomment -%}
{%- case value -%}
  {%- when 'yes' -%}
    <span class="saluva-comp__icon saluva-comp__icon--yes" aria-label="Sí">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    </span>
  {%- when 'no' -%}
    <span class="saluva-comp__icon saluva-comp__icon--no" aria-label="No">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </span>
  {%- else -%}
    <span class="saluva-comp__celltext">{{ text }}</span>
{%- endcase -%}

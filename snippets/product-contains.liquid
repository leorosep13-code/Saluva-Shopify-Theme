{% comment %}
  SALUVA — Bloque "¿Qué contiene?" (cuadrícula 2x2 de imágenes).
  Lee metafields del producto:
    - saluva.contains_1_image, saluva.contains_1_label
    - saluva.contains_2_image, saluva.contains_2_label
    - saluva.contains_3_image, saluva.contains_3_label
    - saluva.contains_4_image, saluva.contains_4_label
  Si no hay metafields, muestra placeholders ilustrativos.
{% endcomment %}

{%- assign mf = product.metafields.saluva -%}

<section class="saluva-contains">
  <div class="container">
    <div class="saluva-block-header">
      <span class="saluva-block-header__chip">Composición</span>
      <h2 class="saluva-block-header__title">¿Qué contiene?</h2>
      <p class="saluva-block-header__sub">Ingredientes seleccionados con propósito</p>
    </div>

    <div class="saluva-contains__grid">
      {% for i in (1..4) %}
        {%- assign img_key = 'contains_' | append: i | append: '_image' -%}
        {%- assign lbl_key = 'contains_' | append: i | append: '_label' -%}
        {%- assign image = mf[img_key] -%}
        {%- assign label = mf[lbl_key] -%}

        <div class="saluva-contains__cell">
          <div class="saluva-contains__img-wrap">
            {% if image != blank %}
              <img src="{{ image | image_url: width: 600 }}"
                   alt="{{ label | default: 'Ingrediente' }}"
                   loading="lazy">
            {% else %}
              {%- case i -%}
                {%- when 1 -%}
                  <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M50 20c-15 5-25 18-25 35a25 25 0 0050 0c0-17-10-30-25-35z"/>
                    <path d="M50 30v40M40 45h20M40 60h20"/>
                  </svg>
                {%- when 2 -%}
                  <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="50" cy="50" r="28"/>
                    <path d="M50 28c-10 6-15 14-15 22 0 9 7 15 15 15s15-6 15-15c0-8-5-16-15-22z"/>
                  </svg>
                {%- when 3 -%}
                  <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M30 70c0-20 10-40 20-40s20 20 20 40"/>
                    <path d="M50 30v40M30 70h40"/>
                  </svg>
                {%- when 4 -%}
                  <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M25 50c0-14 11-25 25-25s25 11 25 25-11 25-25 25-25-11-25-25z"/>
                    <path d="M40 50c0-6 4-10 10-10s10 4 10 10-4 10-10 10-10-4-10-10z"/>
                  </svg>
              {%- endcase -%}
            {% endif %}
          </div>
          <span class="saluva-contains__label">
            {{ label | default: 'Ingrediente activo' }}
          </span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

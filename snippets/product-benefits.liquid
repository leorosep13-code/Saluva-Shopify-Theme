{% comment %}
  SALUVA — Bloque "Beneficios" (sección full-width, cuadrícula 2x2 de imágenes).
  Lee metafields de tipo LISTA del producto:
    - saluva.benefits_images  (List of files → image)
    - saluva.benefits_labels  (List of single-line text)
  Empareja por índice (imagen[i] ↔ etiqueta[i]).
  Si no hay metafields, muestra placeholders ilustrativos.
{% endcomment %}

{%- comment -%} Acepta tanto namespace 'saluva' como 'custom' (default de Shopify Admin) {%- endcomment -%}
{%- assign mf_s = product.metafields.saluva -%}
{%- assign mf_c = product.metafields.custom -%}
{%- assign images = mf_s.benefits_images.value | default: mf_c.benefits_images.value -%}
{%- assign labels = mf_s.benefits_labels.value | default: mf_c.benefits_labels.value -%}

{%- comment -%} DIAGNÓSTICO TEMPORAL: ver keys reales y tipo del primer item de imágenes. {%- endcomment -%}
<!-- saluva-benefits-debug START -->
<!-- product_id={{ product.id }} -->
<!-- saluva keys: {% for kv in mf_s %}{{ kv[0] }}={{ kv[1] | size }}; {% endfor %} -->
<!-- custom keys: {% for kv in mf_c %}{{ kv[0] }}={{ kv[1] | size }}; {% endfor %} -->
<!-- images.size={{ images.size }} labels.size={{ labels.size }} -->
<!-- images[0] id={{ images[0].id }} url={{ images[0].url }} alt={{ images[0].alt }} -->
<!-- images[0] image_url={{ images[0] | image_url: width: 600 }} -->
<!-- images[0] media_type={{ images[0].media_type }} preview={{ images[0].preview_image.src }} -->
<!-- saluva-benefits-debug END -->

<section class="saluva-benefits">
  <div class="container">
    <div class="saluva-block-header">
      <span class="saluva-block-header__chip">Beneficios</span>
      <h2 class="saluva-block-header__title">¿Por qué elegirla?</h2>
      <p class="saluva-block-header__sub">Lo que tu cuerpo va a sentir</p>
    </div>

    <div class="saluva-benefits__grid">
      {% for i in (0..3) %}
        {%- assign image = images[i] -%}
        {%- assign label = labels[i] -%}

        <div class="saluva-benefits__cell">
          <div class="saluva-benefits__img-wrap">
            {%- comment -%} Resuelve URL: MediaImage (image_url filter) o GenericFile (.url) {%- endcomment -%}
            {%- assign img_src = '' -%}
            {%- if image != blank -%}
              {%- assign img_src = image | image_url: width: 600 -%}
              {%- if img_src == blank and image.url -%}
                {%- assign img_src = image.url -%}
              {%- endif -%}
            {%- endif -%}
            {% if img_src != blank %}
              <img src="{{ img_src }}"
                   alt="{{ label | default: 'Beneficio' }}"
                   loading="lazy">
            {% else %}
              {%- case i -%}
                {%- when 0 -%}
                  <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M50 18c-12 12-18 22-18 33a18 18 0 0036 0c0-11-6-21-18-33z"/>
                    <path d="M50 50v25"/>
                  </svg>
                {%- when 1 -%}
                  <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="50" cy="50" r="30"/>
                    <path d="M35 50l10 10 22-22"/>
                  </svg>
                {%- when 2 -%}
                  <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M50 18l8 18 20 2-15 14 5 19-18-10-18 10 5-19-15-14 20-2z"/>
                  </svg>
                {%- when 3 -%}
                  <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M50 22c-15 0-26 11-26 26 0 14 10 22 18 28 4 3 12 3 16 0 8-6 18-14 18-28 0-15-11-26-26-26z"/>
                    <path d="M50 36v22M40 47h20"/>
                  </svg>
              {%- endcase -%}
            {% endif %}
          </div>
          <span class="saluva-benefits__label">
            {{ label | default: 'Beneficio destacado' }}
          </span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% comment %}
  MISOJI — Aviso de envío del carrito (editable desde Customizer → Carrito).
  Settings:
    - settings.cart_shipping_enabled
    - settings.cart_shipping_title
    - settings.cart_shipping_message
    - settings.cart_shipping_subtext
{% endcomment %}

{% if settings.cart_shipping_enabled %}
  <div class="cart-shipping-banner">
    <div class="cart-shipping-banner__icon" aria-hidden="true">
      <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 19V8h13v11"/>
        <path d="M16 12h6l4 5v2h-3"/>
        <circle cx="9" cy="22" r="2.5"/>
        <circle cx="22" cy="22" r="2.5"/>
        <path d="M11.5 22h8"/>
      </svg>
    </div>
    <div class="cart-shipping-banner__copy">
      <span class="cart-shipping-banner__title">{{ settings.cart_shipping_title }}</span>
      <strong class="cart-shipping-banner__message">{{ settings.cart_shipping_message }}</strong>
      {% if settings.cart_shipping_subtext != blank %}
        <span class="cart-shipping-banner__sub">{{ settings.cart_shipping_subtext }}</span>
      {% endif %}
    </div>
  </div>
{% endif %}

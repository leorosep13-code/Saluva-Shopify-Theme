    { "type": "image_picker", "id": "promo_4_image_mobile", "label": "Imagen móvil - Promo 4" },
    { "type": "url", "id": "promo_4_link", "label": "Enlace - Promo 4" },
    { "type": "header", "content": "Promoción 5" },
    { "type": "image_picker", "id": "promo_5_image_desktop", "label": "Imagen desktop - Promo 5" },
    { "type": "image_picker", "id": "promo_5_image_mobile", "label": "Imagen móvil - Promo 5" },

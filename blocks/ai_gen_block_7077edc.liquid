    { "type": "image_picker", "id": "promo_3_image_mobile", "label": "Imagen móvil - Promo 3" },
    { "type": "url", "id": "promo_3_link", "label": "Enlace - Promo 3" },
    { "type": "header", "content": "Promoción 4" },

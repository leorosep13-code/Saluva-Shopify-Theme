{% doc %}
  Banner deslizable de promociones con imagen de fondo para desktop y móvil.
  Click en cualquier parte del banner lleva al enlace configurado.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
.promo-slider-{{ ai_gen_id }} {
  position: relative;
  width: 100%;
  overflow: hidden;
  cursor: pointer;
}

.promo-slider-{{ ai_gen_id }} .slides-wrapper {
  display: flex;
  transition: transform 0.6s ease;
  height: 500px;
}

@media (max-width: 768px) {
  .promo-slider-{{ ai_gen_id }} .slides-wrapper {
    height: 300px;
  }
}

.promo-slider-{{ ai_gen_id }} .slide {
  min-width: 100%;
  position: relative;
  overflow: hidden;
}

.promo-slider-{{ ai_gen_id }} .slide a {
  display: block;
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0; left: 0;
  z-index: 2;
}

.promo-slider-{{ ai_gen_id }} .slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.promo-slider-{{ ai_gen_id }} .slide .img-desktop {
  display: block;
}

.promo-slider-{{ ai_gen_id }} .slide .img-mobile {
  display: none;
}

@media (max-width: 768px) {
  .promo-slider-{{ ai_gen_id }} .slide .img-desktop {
    display: none;
  }
  .promo-slider-{{ ai_gen_id }} .slide .img-mobile {
    display: block;
  }
}

.promo-slider-{{ ai_gen_id }} .arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  background: rgba(0,0,0,0.35);
  border: none;
  color: #fff;
  font-size: 24px;
  padding: 12px 16px;
  cursor: pointer;
  border-radius: 4px;
}

.promo-slider-{{ ai_gen_id }} .arrow-prev { left: 12px; }
.promo-slider-{{ ai_gen_id }} .arrow-next { right: 12px; }

.promo-slider-{{ ai_gen_id }} .dots {
  position: absolute;
  bottom: 12px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8px;
  z-index: 10;
}

.promo-slider-{{ ai_gen_id }} .dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  cursor: pointer;
  border: none;
}

.promo-slider-{{ ai_gen_id }} .dot.active {
  background: #fff;
}
{% endstyle %}

<div class="promo-slider-{{ ai_gen_id }}" id="slider-{{ ai_gen_id }}">
  <div class="slides-wrapper" id="slides-{{ ai_gen_id }}">

    {% if block.settings.promo_1_image_desktop != blank or block.settings.promo_1_image_mobile != blank %}
    <div class="slide">
      <a href="{{ block.settings.promo_1_link }}" aria-label="Promoción 1"></a>
      {% if block.settings.promo_1_image_desktop != blank %}
        {{ block.settings.promo_1_image_desktop | image_url: width: 1920 | image_tag: class: 'img-desktop', alt: 'Promoción 1' }}
      {% endif %}
      {% if block.settings.promo_1_image_mobile != blank %}
        {{ block.settings.promo_1_image_mobile | image_url: width: 800 | image_tag: class: 'img-mobile', alt: 'Promoción 1' }}
      {% elsif block.settings.promo_1_image_desktop != blank %}
        {{ block.settings.promo_1_image_desktop | image_url: width: 800 | image_tag: class: 'img-mobile', alt: 'Promoción 1' }}
      {% endif %}
    </div>
    {% endif %}

    {% if block.settings.promo_2_image_desktop != blank or block.settings.promo_2_image_mobile != blank %}
    <div class="slide">
      <a href="{{ block.settings.promo_2_link }}" aria-label="Promoción 2"></a>
      {% if block.settings.promo_2_image_desktop != blank %}
        {{ block.settings.promo_2_image_desktop | image_url: width: 1920 | image_tag: class: 'img-desktop', alt: 'Promoción 2' }}
      {% endif %}
      {% if block.settings.promo_2_image_mobile != blank %}
        {{ block.settings.promo_2_image_mobile | image_url: width: 800 | image_tag: class: 'img-mobile', alt: 'Promoción 2' }}
      {% elsif block.settings.promo_2_image_desktop != blank %}
        {{ block.settings.promo_2_image_desktop | image_url: width: 800 | image_tag: class: 'img-mobile', alt: 'Promoción 2' }}
      {% endif %}
    </div>
    {% endif %}

    {% if block.settings.promo_3_image_desktop != blank or block.settings.promo_3_image_mobile != blank %}
    <div class="slide">
      <a href="{{ block.settings.promo_3_link }}" aria-label="Promoción 3"></a>
      {% if block.settings.promo_3_image_desktop != blank %}
        {{ block.settings.promo_3_image_desktop | image_url: width: 1920 | image_tag: class: 'img-desktop', alt: 'Promoción 3' }}
      {% endif %}
      {% if block.settings.promo_3_image_mobile != blank %}
        {{ block.settings.promo_3_image_mobile | image_url: width: 800 | image_tag: class: 'img-mobile', alt: 'Promoción 3' }}
      {% elsif block.settings.promo_3_image_desktop != blank %}
        {{ block.settings.promo_3_image_desktop | image_url: width: 800 | image_tag: class: 'img-mobile', alt: 'Promoción 3' }}
      {% endif %}
    </div>
    {% endif %}

    {% if block.settings.promo_4_image_desktop != blank or block.settings.promo_4_image_mobile != blank %}
    <div class="slide">
      <a href="{{ block.settings.promo_4_link }}" aria-label="Promoción 4"></a>
      {% if block.settings.promo_4_image_desktop != blank %}
        {{ block.settings.promo_4_image_desktop | image_url: width: 1920 | image_tag: class: 'img-desktop', alt: 'Promoción 4' }}
      {% endif %}
      {% if block.settings.promo_4_image_mobile != blank %}
        {{ block.settings.promo_4_image_mobile | image_url: width: 800 | image_tag: class: 'img-mobile', alt: 'Promoción 4' }}
      {% elsif block.settings.promo_4_image_desktop != blank %}
        {{ block.settings.promo_4_image_desktop | image_url: width: 800 | image_tag: class: 'img-mobile', alt: 'Promoción 4' }}
      {% endif %}
    </div>
    {% endif %}

    {% if block.settings.promo_5_image_desktop != blank or block.settings.promo_5_image_mobile != blank %}
    <div class="slide">
      <a href="{{ block.settings.promo_5_link }}" aria-label="Promoción 5"></a>
      {% if block.settings.promo_5_image_desktop != blank %}
        {{ block.settings.promo_5_image_desktop | image_url: width: 1920 | image_tag: class: 'img-desktop', alt: 'Promoción 5' }}
      {% endif %}
      {% if block.settings.promo_5_image_mobile != blank %}
        {{ block.settings.promo_5_image_mobile | image_url: width: 800 | image_tag: class: 'img-mobile', alt: 'Promoción 5' }}
      {% elsif block.settings.promo_5_image_desktop != blank %}
        {{ block.settings.promo_5_image_desktop | image_url: width: 800 | image_tag: class: 'img-mobile', alt: 'Promoción 5' }}
      {% endif %}
    </div>
    {% endif %}

  </div>

  <button class="arrow arrow-prev" id="prev-{{ ai_gen_id }}">&#8592;</button>
  <button class="arrow arrow-next" id="next-{{ ai_gen_id }}">&#8594;</button>

  <div class="dots" id="dots-{{ ai_gen_id }}"></div>
</div>

<script>
(function() {
  const slider = document.getElementById('slider-{{ ai_gen_id }}');
  const wrapper = document.getElementById('slides-{{ ai_gen_id }}');
  const slides = wrapper.querySelectorAll('.slide');
  const dotsContainer = document.getElementById('dots-{{ ai_gen_id }}');
  let current = 0;
  let autoplay;

  if (slides.length === 0) return;

  // Crear dots
  slides.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.classList.add('dot');
    if (i === 0) dot.classList.add('active');
    dot.addEventListener('click', () => goTo(i));
    dotsContainer.appendChild(dot);
  });

  function goTo(index) {
    slides[current].querySelector('.dot');
    dotsContainer.querySelectorAll('.dot')[current].classList.remove('active');
    current = (index + slides.length) % slides.length;
    wrapper.style.transform = `translateX(-${current * 100}%)`;
    dotsContainer.querySelectorAll('.dot')[current].classList.add('active');
  }

  document.getElementById('prev-{{ ai_gen_id }}').addEventListener('click', () => {
    goTo(current - 1);
    resetAutoplay();
  });

  document.getElementById('next-{{ ai_gen_id }}').addEventListener('click', () => {
    goTo(current + 1);
    resetAutoplay();
  });

  function startAutoplay() {
    autoplay = setInterval(() => goTo(current + 1), 5000);
  }

  function resetAutoplay() {
    clearInterval(autoplay);
    startAutoplay();
  }

  // Swipe
  let startX = 0;
  wrapper.addEventListener('touchstart', e => startX = e.touches[0].clientX);
  wrapper.addEventListener('touchend', e => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      goTo(diff > 0 ? current + 1 : current - 1);
      resetAutoplay();
    }
  });

  startAutoplay();
})();
</script>


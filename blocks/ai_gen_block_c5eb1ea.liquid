{% doc %}
  @prompt
    banner promocional alargado que tenga movimiento 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-banner-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
    position: relative;
  }

  .ai-promo-banner__track-{{ ai_gen_id }} {
    display: flex;
    width: max-content;
    animation: ai-promo-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
  }

  .ai-promo-banner__content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    padding: 0 {{ block.settings.item_spacing | divided_by: 2 }}px;
    white-space: nowrap;
  }

  .ai-promo-banner__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
  }

  .ai-promo-banner__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-promo-banner__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-promo-banner__separator-{{ ai_gen_id }} {
    width: {{ block.settings.separator_size }}px;
    height: {{ block.settings.separator_size }}px;
    background-color: {{ block.settings.separator_color }};
    border-radius: 50%;
    flex-shrink: 0;
  }

  @keyframes ai-promo-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-promo-banner-{{ ai_gen_id }}:hover .ai-promo-banner__track-{{ ai_gen_id }} {
    animation-play-state: paused;
  }

  @media screen and (max-width: 749px) {
    .ai-promo-banner__item-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    .ai-promo-banner__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<promo-banner-{{ ai_gen_id }} class="ai-promo-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-promo-banner__track-{{ ai_gen_id }}">
    <div class="ai-promo-banner__content-{{ ai_gen_id }}">
      {% if block.settings.show_icon %}
        <div class="ai-promo-banner__item-{{ ai_gen_id }}">
          <span class="ai-promo-banner__icon-{{ ai_gen_id }}">
            {% if block.settings.icon_type == 'star' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% elsif block.settings.icon_type == 'tag' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/>
              </svg>
            {% elsif block.settings.icon_type == 'truck' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M18 18.5a1.5 1.5 0 0 1-1.5-1.5 1.5 1.5 0 0 1 1.5-1.5 1.5 1.5 0 0 1 1.5 1.5 1.5 1.5 0 0 1-1.5 1.5m1.5-9l1.96 2.5H17V9.5m-11 9A1.5 1.5 0 0 1 4.5 17 1.5 1.5 0 0 1 6 15.5 1.5 1.5 0 0 1 7.5 17 1.5 1.5 0 0 1 6 18.5M20 8h-3V4H3c-1.11 0-2 .89-2 2v11h2a3 3 0 0 0 3 3 3 3 0 0 0 3-3h6a3 3 0 0 0 3 3 3 3 0 0 0 3-3h2v-5l-3-4z"/>
              </svg>
            {% elsif block.settings.icon_type == 'gift' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M22 12v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8h20zm0-2H2V7a2 2 0 0 1 2-2h5.17a3 3 0 0 1-.17 1 3 3 0 0 1 3 3h4a3 3 0 0 1 3-3 3 3 0 0 1-.17-1H20a2 2 0 0 1 2 2v3zM11 20v-8H4v6a2 2 0 0 0 2 2h5zm2 0h5a2 2 0 0 0 2-2v-6h-7v8zM9 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm6 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
              </svg>
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endif %}
          </span>
          <span>{{ block.settings.promo_text }}</span>
        </div>
      {% else %}
        <div class="ai-promo-banner__item-{{ ai_gen_id }}">
          <span>{{ block.settings.promo_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.show_separator %}
        <span class="ai-promo-banner__separator-{{ ai_gen_id }}"></span>
      {% endif %}
    </div>

    <div class="ai-promo-banner__content-{{ ai_gen_id }}" aria-hidden="true">
      {% if block.settings.show_icon %}
        <div class="ai-promo-banner__item-{{ ai_gen_id }}">
          <span class="ai-promo-banner__icon-{{ ai_gen_id }}">
            {% if block.settings.icon_type == 'star' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% elsif block.settings.icon_type == 'tag' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/>
              </svg>
            {% elsif block.settings.icon_type == 'truck' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M18 18.5a1.5 1.5 0 0 1-1.5-1.5 1.5 1.5 0 0 1 1.5-1.5 1.5 1.5 0 0 1 1.5 1.5 1.5 1.5 0 0 1-1.5 1.5m1.5-9l1.96 2.5H17V9.5m-11 9A1.5 1.5 0 0 1 4.5 17 1.5 1.5 0 0 1 6 15.5 1.5 1.5 0 0 1 7.5 17 1.5 1.5 0 0 1 6 18.5M20 8h-3V4H3c-1.11 0-2 .89-2 2v11h2a3 3 0 0 0 3 3 3 3 0 0 0 3-3h6a3 3 0 0 0 3 3 3 3 0 0 0 3-3h2v-5l-3-4z"/>
              </svg>
            {% elsif block.settings.icon_type == 'gift' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M22 12v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8h20zm0-2H2V7a2 2 0 0 1 2-2h5.17a3 3 0 0 1-.17 1 3 3 0 0 1 3 3h4a3 3 0 0 1 3-3 3 3 0 0 1-.17-1H20a2 2 0 0 1 2 2v3zM11 20v-8H4v6a2 2 0 0 0 2 2h5zm2 0h5a2 2 0 0 0 2-2v-6h-7v8zM9 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm6 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
              </svg>
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endif %}
          </span>
          <span>{{ block.settings.promo_text }}</span>
        </div>
      {% else %}
        <div class="ai-promo-banner__item-{{ ai_gen_id }}">
          <span>{{ block.settings.promo_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.show_separator %}
        <span class="ai-promo-banner__separator-{{ ai_gen_id }}"></span>
      {% endif %}
    </div>
  </div>
</promo-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class PromoBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-promo-banner__track-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-promo-banner__content-{{ ai_gen_id }}');
        
        if (this.track && this.content) {
          this.duplicateContent();
        }
      }

      duplicateContent() {
        const contentWidth = this.content.offsetWidth;
        const containerWidth = this.offsetWidth;
        const duplicatesNeeded = Math.ceil(containerWidth / contentWidth) + 2;

        for (let i = 0; i < duplicatesNeeded; i++) {
          const clone = this.content.cloneNode(true);
          clone.setAttribute('aria-hidden', 'true');
          this.track.appendChild(clone);
        }
      }
    }

    customElements.define('promo-banner-{{ ai_gen_id }}', PromoBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Banner promocional",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Texto promocional",
      "default": "Envío gratis en compras superiores a $100.000"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Mostrar ícono",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Tipo de ícono",
      "options": [
        {
          "value": "star",
          "label": "Estrella"
        },
        {
          "value": "tag",
          "label": "Etiqueta"
        },
        {
          "value": "truck",
          "label": "Camión"
        },
        {
          "value": "gift",
          "label": "Regalo"
        }
      ],
      "default": "tag"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Mostrar separador",
      "default": true
    },
    {
      "type": "header",
      "content": "Estilo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#a4c93b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color de ícono",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Color de separador",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Tamaño de fuente",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Peso de fuente",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medio"
        },
        {
          "value": "600",
          "label": "Semi negrita"
        },
        {
          "value": "700",
          "label": "Negrita"
        }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Tamaño de ícono",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "separator_size",
      "label": "Tamaño de separador",
      "min": 4,
      "max": 12,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Espaciado vertical",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Espaciado entre elementos",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Espacio entre ícono y texto",
      "min": 4,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Animación"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Velocidad de animación",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Banner promocional"
    }
  ]
}
{% endschema %}

<!DOCTYPE html>
<html lang="es" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — {{ shop.name }}</title>
  <meta name="description" content="{{ page_description }}">

  {% if settings.og_image %}
    <meta property="og:image" content="{{ settings.og_image | image_url: width: 1200 }}">
  {% endif %}
  {% if settings.favicon %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {% endif %}

  {%- comment -%} Inyectar CSS variables desde settings del customizer {%- endcomment -%}
  <style>
    :root {
      --color-primary: {{ settings.color_primary }};
      --color-secondary: {{ settings.color_secondary }};
      --color-bg: {{ settings.color_background }};
      --color-text: {{ settings.color_text }};
      --color-text-muted: {{ settings.color_text_muted }};
      --color-accent: {{ settings.color_accent }};
      --font-size-base: {{ settings.font_size_base }}px;
      --logo-width: {{ settings.logo_width }}px;
    }
  </style>

  {{ settings.font_heading | font_face: font_display: 'swap' }}
  {{ settings.font_body | font_face: font_display: 'swap' }}

  {{ 'saluva-base.css' | asset_url | stylesheet_tag }}
  {{ 'saluva-sections.css' | asset_url | stylesheet_tag }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  {{ content_for_header }}

  <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
</head>
<body class="template-{{ template.name }}">

  {% section 'promo-bar' %}
  {% section 'header' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Toast notification container -->
  <div class="toast-container" id="toast-container" aria-live="polite"></div>

  <!-- Floating checkout button -->
  <a href="/cart" class="floating-checkout" id="floating-checkout" style="display: none;">
    <svg class="floating-checkout__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
    <span class="floating-checkout__label">PAGAR</span>
    <span class="floating-checkout__count" id="floating-checkout-count">0</span>
  </a>

  <!-- Scroll to top button -->
  <button class="scroll-top-btn" id="scroll-top-btn" aria-label="Volver arriba">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

  {{ 'saluva-scripts.js' | asset_url | script_tag }}
</body>
</html>

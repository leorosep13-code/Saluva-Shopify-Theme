<style>
  .related-product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }
  .related-product-card:hover img {
    transform: scale(1.05);
  }
  @media (max-width: 768px) {
    .related-products-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 16px !important;
    }
  }
</style>

<section class="product-page" style="padding: 40px 0 70px;">
  <div class="container">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start;">

      <!-- Product Images -->
      <div>
        {% if product.featured_image != blank %}
          <div style="border-radius: 20px; overflow: hidden; background: linear-gradient(135deg, var(--color-primary-10), var(--color-secondary-10));">
            <img src="{{ product.featured_image | image_url: width: 800 }}"
                 alt="{{ product.featured_image.alt | default: product.title }}"
                 style="width: 100%; display: block;">
          </div>
        {% endif %}
        {% if product.images.size > 1 %}
          <div style="display: flex; gap: 12px; margin-top: 16px;">
            {% for image in product.images offset: 1 limit: 4 %}
              <div style="flex: 1; border-radius: 12px; overflow: hidden; border: 1px solid var(--color-border);">
                <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt }}" style="width: 100%; display: block;">
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Product Info -->
      <div>
        <p style="font-size: 12px; font-weight: 700; color: var(--color-primary); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px;">
          {{ product.type }}
        </p>
        <h1 style="font-size: 36px; font-weight: 800; line-height: 1.2; margin-bottom: 16px;">
          {{ product.title }}
        </h1>

        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
          <span style="font-size: 28px; font-weight: 800;">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <span style="font-size: 18px; color: var(--color-text-light); text-decoration: line-through;">
              {{ product.compare_at_price | money }}
            </span>
            {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
            <span style="font-size: 13px; font-weight: 700; background: var(--color-secondary); color: #fff; padding: 4px 12px; border-radius: 12px;">
              -{{ discount }}%
            </span>
          {% endif %}
        </div>

        <div style="font-size: 15px; color: var(--color-text-muted); line-height: 1.7; margin-bottom: 32px;">
          {{ product.description }}
        </div>

        {% form 'product', product %}
          {% if product.variants.size > 1 %}
            <div style="margin-bottom: 20px;">
              <label for="variant-select" style="font-size: 13px; font-weight: 700; display: block; margin-bottom: 8px;">
                Variante
              </label>
              <select name="id" id="variant-select" style="width: 100%; padding: 12px 16px; border: 2px solid var(--color-border); border-radius: 12px; font-family: var(--font-family); font-size: 14px;">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.title }} — {{ variant.price | money }}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% else %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {% endif %}

          <button type="submit"
                  class="btn btn--primary btn--lg"
                  style="width: 100%; justify-content: center; padding: 16px; font-size: 16px;"
                  {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}
              Agregar al Carrito
            {% else %}
              Agotado
            {% endif %}
          </button>
        {% endform %}

        <!-- Trust signals -->
        <div style="margin-top: 24px; display: flex; flex-direction: column; gap: 10px;">
          {% assign trust_items = "🌱 100% Natural|🚚 Envío gratis en pedidos +$80K|🔒 Pago seguro|↩️ Devolución en 30 días" | split: "|" %}
          {% for item in trust_items %}
            <div style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--color-text-muted);">
              {{ item }}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Productos Recomendados -->
{% assign current_product = product %}
{% assign related_products_list = recommendations.products %}

{% if related_products_list == blank or related_products_list.size == 0 %}
  {% assign related_products_list = collections.all.products %}
{% endif %}

<section id="related-products" style="padding: 40px 0 70px;">
  <div class="container">
    <div style="text-align: center; margin-bottom: 40px;">
      <p style="font-size: 12px; font-weight: 700; color: var(--color-primary); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px;">
        Descubre más
      </p>
      <h2 style="font-size: 28px; font-weight: 800; line-height: 1.2;">
        Productos que te pueden interesar
      </h2>
    </div>

    <div class="related-products-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;">
      {% assign shown = 0 %}
      {% for p in related_products_list %}
        {% if p.id != current_product.id and shown < 4 and p.available %}
          <a href="{{ p.url }}" class="related-product-card" style="text-decoration: none; color: inherit; display: block; border-radius: 16px; overflow: hidden; border: 1px solid var(--color-border); transition: transform 0.3s, box-shadow 0.3s;">
            <div style="aspect-ratio: 1; overflow: hidden; background: linear-gradient(135deg, var(--color-primary-10), var(--color-secondary-10));">
              {% if p.featured_image %}
                <img src="{{ p.featured_image | image_url: width: 400 }}"
                     alt="{{ p.featured_image.alt | default: p.title }}"
                     loading="lazy"
                     style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s;">
              {% endif %}
            </div>
            <div style="padding: 16px;">
              {% if p.type != blank %}
                <p style="font-size: 11px; font-weight: 700; color: var(--color-primary); letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 4px;">
                  {{ p.type }}
                </p>
              {% endif %}
              <h3 style="font-size: 15px; font-weight: 700; margin-bottom: 8px; line-height: 1.3;">
                {{ p.title }}
              </h3>
              <div style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 16px; font-weight: 800;">{{ p.price | money }}</span>
                {% if p.compare_at_price > p.price %}
                  <span style="font-size: 13px; color: var(--color-text-light); text-decoration: line-through;">
                    {{ p.compare_at_price | money }}
                  </span>
                {% endif %}
              </div>
            </div>
          </a>
          {% assign shown = shown | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Producto Principal",
  "settings": []
}
{% endschema %}

{% comment %}
  SALUVA — Página de Producto Premium
  Mobile-first con carrusel, reviews, rating y WhatsApp flotante
  CSS → saluva-sections.css | JS → saluva-scripts.js
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="pdp" id="product-page">

  <!-- ═══ CARRUSEL DE IMÁGENES / VIDEOS ═══ -->
  <div class="pdp__gallery">
    <div class="pdp__carousel" id="pdp-carousel">
      <div class="pdp__carousel-track" id="pdp-carousel-track">
        {% for media in product.media %}
          <div class="pdp__carousel-slide">
            {% if media.media_type == 'image' %}
              <img
                src="{{ media | image_url: width: 600 }}"
                alt="{{ media.alt | default: product.title }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                draggable="false"
              >
            {% elsif media.media_type == 'video' %}
              <div class="pdp__video-wrapper">
                {{ media | video_tag: autoplay: false, controls: true, muted: false }}
              </div>
            {% elsif media.media_type == 'external_video' %}
              <div class="pdp__video-wrapper">
                {{ media | external_video_tag }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
    {% if product.media.size > 1 %}
      <div class="pdp__carousel-dots" id="pdp-carousel-dots">
        {% for media in product.media %}
          <button
            class="pdp__carousel-dot{% if forloop.first %} active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Imagen {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
    <!-- Thumbnails (desktop) -->
    {% if product.media.size > 1 %}
      <div class="pdp__thumbs">
        {% for media in product.media %}
          {% if media.media_type == 'image' %}
            <button class="pdp__thumb{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}">
              <img src="{{ media | image_url: width: 120 }}" alt="{{ media.alt | default: product.title }}" loading="lazy">
            </button>
          {% else %}
            <button class="pdp__thumb pdp__thumb--video{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}">
              {% if media.preview_image %}
                <img src="{{ media.preview_image | image_url: width: 120 }}" alt="Video" loading="lazy">
              {% endif %}
              <svg class="pdp__thumb-play" width="20" height="20" viewBox="0 0 24 24" fill="#fff"><polygon points="5 3 19 12 5 21"/></svg>
            </button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- ═══ INFO DEL PRODUCTO ═══ -->
  <div class="pdp__info">

    <!-- Header: tipo | título + share/wishlist -->
    <div class="pdp__header">
      <div>
        {% if product.type != blank %}
          <span class="pdp__type">{{ product.type }}</span>
        {% endif %}
        <h1 class="pdp__title">{{ product.title }}</h1>
      </div>
      <div class="pdp__actions-top">
        <button class="pdp__icon-btn" id="pdp-share" aria-label="Compartir">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        </button>
      </div>
    </div>

    <!-- Vendedor + Rating -->
    <div class="pdp__meta">
      <span class="pdp__vendor">{{ product.vendor }}</span>
      <div class="pdp__rating" id="pdp-rating-summary">
        <div class="pdp__stars" data-rating="0">
          {% for i in (1..5) %}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          {% endfor %}
        </div>
        <span class="pdp__rating-count">0.0 (0)</span>
      </div>
    </div>

    <!-- Precio -->
    <div class="pdp__price-row">
      <span class="pdp__price" id="pdp-price">{{ current_variant.price | money }}</span>
      {% if current_variant.compare_at_price > current_variant.price %}
        <span class="pdp__compare" id="pdp-compare">{{ current_variant.compare_at_price | money }}</span>
      {% endif %}
    </div>
    {% if current_variant.compare_at_price > current_variant.price %}
      {% assign discount_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price %}
      {% assign savings = current_variant.compare_at_price | minus: current_variant.price %}
      <div class="pdp__savings" id="pdp-savings">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        <span>{{ discount_pct }}% OFF — Ahorras {{ savings | money }}</span>
      </div>
    {% endif %}

    <!-- Variantes -->
    {% if product.variants.size > 1 %}
      {% for option in product.options_with_values %}
        <div class="pdp__option">
          <label class="pdp__option-label">{{ option.name }}: <strong id="pdp-option-{{ forloop.index0 }}-selected">{{ option.selected_value }}</strong></label>
          <div class="pdp__option-values">
            {% for value in option.values %}
              <button
                class="pdp__option-btn{% if value == option.selected_value %} active{% endif %}"
                data-option-index="{{ forloop.parentloop.index0 }}"
                data-value="{{ value }}"
              >{{ value }}</button>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    {% endif %}

    <!-- Cantidad + Agregar (desktop) -->
    <div class="pdp__add-row pdp__add-row--desktop">
      {% form 'product', product, id: 'pdp-form-desktop' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}" id="pdp-variant-id-desktop">
        <div class="pdp__qty">
          <button type="button" class="qty-btn pdp__qty-btn" data-action="minus" aria-label="Menos">−</button>
          <input type="number" name="quantity" value="1" min="1" class="pdp__qty-input" onwheel="this.blur()">
          <button type="button" class="qty-btn pdp__qty-btn" data-action="plus" aria-label="Más">+</button>
        </div>
        <button type="submit" class="btn btn--primary pdp__add-btn product-add-btn" {% unless current_variant.available %}disabled{% endunless %}>
          {% if current_variant.available %}Agregar al Carrito{% else %}Agotado{% endif %}
        </button>
      {% endform %}
    </div>

    <!-- Trust signals -->
    <div class="pdp__trust">
      <div class="pdp__trust-item"><span>🌱</span> 100% Natural</div>
      <div class="pdp__trust-item"><span>🚚</span> Envío gratis +$160K</div>
      <div class="pdp__trust-item"><span>🔒</span> Pago seguro</div>
      <div class="pdp__trust-item"><span>↩️</span> Devolución 30 días</div>
    </div>

    <!-- Descripción -->
    <details class="pdp__details" open>
      <summary class="pdp__details-summary">Descripción del producto</summary>
      <div class="pdp__details-content">
        {{ product.description }}
      </div>
    </details>
  </div>
</section>

<!-- ═══ SECCIÓN DE VALORACIONES Y COMENTARIOS ═══ -->
<section class="pdp-reviews" id="pdp-reviews">
  <div class="container">
    <div class="pdp-reviews__header">
      <h2 class="pdp-reviews__title">Valoraciones y Comentarios</h2>
      <button class="btn btn--primary btn--md" id="pdp-review-toggle">Escribir una reseña</button>
    </div>

    <!-- Formulario de reseña -->
    <div class="pdp-reviews__form-wrap" id="pdp-review-form-wrap" style="display:none;">
      <form class="pdp-reviews__form" id="pdp-review-form">
        <div class="pdp-reviews__form-row">
          <label class="pdp-reviews__label">Tu nombre</label>
          <input type="text" class="pdp-reviews__input" id="review-name" required placeholder="Nombre">
        </div>
        <div class="pdp-reviews__form-row">
          <label class="pdp-reviews__label">Valoración</label>
          <div class="pdp-reviews__star-input" id="review-star-input">
            {% for i in (1..5) %}
              <button type="button" class="pdp-reviews__star-btn" data-star="{{ i }}" aria-label="{{ i }} estrellas">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </button>
            {% endfor %}
          </div>
        </div>
        <div class="pdp-reviews__form-row">
          <label class="pdp-reviews__label">Comentario</label>
          <textarea class="pdp-reviews__textarea" id="review-comment" rows="4" required placeholder="Cuéntanos tu experiencia con este producto..."></textarea>
        </div>
        <div class="pdp-reviews__form-row">
          <label class="pdp-reviews__label">Foto (opcional)</label>
          <label class="pdp-reviews__upload-label" id="review-upload-label">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            Agregar imagen
            <input type="file" accept="image/*" class="pdp-reviews__upload-input" id="review-image-input">
          </label>
          <div class="pdp-reviews__upload-preview" id="review-image-preview">
            <img src="" alt="Preview" id="review-image-preview-img">
            <button type="button" class="pdp-reviews__upload-remove" id="review-image-remove" aria-label="Quitar imagen">✕</button>
          </div>
        </div>
        <button type="submit" class="btn btn--primary btn--md">Publicar reseña</button>
      </form>
    </div>

    <!-- Lista de reseñas -->
    <div class="pdp-reviews__list" id="pdp-reviews-list">
      <!-- Las reseñas se renderizan por JS desde localStorage -->
    </div>

    <p class="pdp-reviews__empty" id="pdp-reviews-empty">Sé el primero en dejar una reseña de este producto.</p>
  </div>
</section>

<!-- ═══ PRODUCTOS RECOMENDADOS ═══ -->
{% assign current_product = product %}
{% assign related_products_list = recommendations.products %}
{% if related_products_list == blank or related_products_list.size == 0 %}
  {% assign related_products_list = collections.all.products %}
{% endif %}

<section class="pdp-related" id="related-products">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-header__label">Descubre más</span>
      <h2 class="section-header__title">Productos que te pueden interesar</h2>
    </div>
    <div class="pdp-related__grid">
      {% assign shown = 0 %}
      {% for p in related_products_list %}
        {% if p.id != current_product.id and shown < 4 and p.available %}
          <a href="{{ p.url }}" class="pdp-related__card">
            <div class="pdp-related__card-img">
              {% if p.featured_image %}
                <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.featured_image.alt | default: p.title }}" loading="lazy">
              {% endif %}
            </div>
            <div class="pdp-related__card-info">
              {% if p.type != blank %}
                <span class="pdp-related__card-type">{{ p.type }}</span>
              {% endif %}
              <h3 class="pdp-related__card-title">{{ p.title }}</h3>
              <div class="pdp-related__card-price">
                <span>{{ p.price | money }}</span>
                {% if p.compare_at_price > p.price %}
                  <span class="pdp-related__card-compare">{{ p.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>
          </a>
          {% assign shown = shown | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══ BARRA STICKY MOBILE: Cantidad + Agregar ═══ -->
<div class="pdp__sticky-bar" id="pdp-sticky-bar">
  {% form 'product', product, id: 'pdp-form-mobile' %}
    <input type="hidden" name="id" value="{{ current_variant.id }}" id="pdp-variant-id-mobile">
    <div class="pdp__qty pdp__qty--sticky">
      <button type="button" class="qty-btn pdp__qty-btn" data-action="minus" aria-label="Menos">−</button>
      <input type="number" name="quantity" value="1" min="1" class="pdp__qty-input" onwheel="this.blur()">
      <button type="button" class="qty-btn pdp__qty-btn" data-action="plus" aria-label="Más">+</button>
    </div>
    <button type="submit" class="btn btn--primary pdp__add-btn pdp__add-btn--sticky product-add-btn" {% unless current_variant.available %}disabled{% endunless %}>
      {% if current_variant.available %}Agregar al Carrito{% else %}Agotado{% endif %}
    </button>
  {% endform %}
</div>

<!-- ═══ BOTÓN FLOTANTE WHATSAPP ═══ -->
<a
  href="https://wa.me/{{ section.settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}?text={{ section.settings.whatsapp_message | url_encode }}%20{{ product.title | url_encode }}"
  class="pdp__whatsapp"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
</a>

<!-- Variant data for JS -->
<script type="application/json" id="pdp-variants-json">
  {{ product.variants | json }}
</script>

{% schema %}
{
  "name": "Producto Principal",
  "settings": [
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Número de WhatsApp",
      "info": "Con código de país. Ej: 573001234567",
      "default": "573001234567"
    },
    {
      "type": "text",
      "id": "whatsapp_message",
      "label": "Mensaje predeterminado",
      "default": "Hola, estoy interesada en"
    }
  ]
}
{% endschema %}

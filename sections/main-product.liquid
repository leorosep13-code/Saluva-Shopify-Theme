{% comment %}
  MISOJI — Página de Producto Premium
  Mobile-first con carrusel, reviews, rating y WhatsApp flotante
  CSS → saluva-sections.css | JS → saluva-scripts.js
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- comment -%} ── Reseñas locales (metaobjetos en product.metafields.custom.resenas) ── {%- endcomment -%}
{%- liquid
  assign reviews = product.metafields.custom.resenas.value
  assign reviews_count = 0
  assign reviews_total = 0
  assign star5 = 0
  assign star4 = 0
  assign star3 = 0
  assign star2 = 0
  assign star1 = 0
  if reviews
    assign reviews_count = reviews.size
    for r in reviews
      assign rv = r.estrellas.value | default: 0 | round
      assign reviews_total = reviews_total | plus: rv
      case rv
        when 5
          assign star5 = star5 | plus: 1
        when 4
          assign star4 = star4 | plus: 1
        when 3
          assign star3 = star3 | plus: 1
        when 2
          assign star2 = star2 | plus: 1
        else
          assign star1 = star1 | plus: 1
      endcase
    endfor
  endif
  assign reviews_avg = 0
  if reviews_count > 0
    assign reviews_avg = reviews_total | times: 1.0 | divided_by: reviews_count
  endif
-%}

<section class="pdp" id="product-page">

  <!-- ═══ CARRUSEL DE IMÁGENES / VIDEOS ═══ -->
  <div class="pdp__gallery">
    <div class="pdp__carousel" id="pdp-carousel">
      <div class="pdp__carousel-track" id="pdp-carousel-track">
        {% for media in product.media %}
          <div class="pdp__carousel-slide">
            {% if media.media_type == 'image' %}
              <img
                src="{{ media | image_url: width: 600 }}"
                data-zoom="{{ media | image_url: width: 2000 }}"
                alt="{{ media.alt | default: product.title }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                draggable="false"
              >
            {% elsif media.media_type == 'video' %}
              <div class="pdp__video-wrapper">
                {{ media | video_tag: autoplay: false, controls: true, muted: false }}
              </div>
            {% elsif media.media_type == 'external_video' %}
              <div class="pdp__video-wrapper">
                {{ media | external_video_tag }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
    {% if product.media.size > 1 %}
      <div class="pdp__carousel-dots" id="pdp-carousel-dots">
        {% for media in product.media %}
          <button
            class="pdp__carousel-dot{% if forloop.first %} active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Imagen {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
    <!-- Thumbnails (desktop) -->
    {% if product.media.size > 1 %}
      <div class="pdp__thumbs">
        {% for media in product.media %}
          {% if media.media_type == 'image' %}
            <button class="pdp__thumb{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}">
              <img src="{{ media | image_url: width: 120 }}" alt="{{ media.alt | default: product.title }}" loading="lazy">
            </button>
          {% else %}
            <button class="pdp__thumb pdp__thumb--video{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}">
              {% if media.preview_image %}
                <img src="{{ media.preview_image | image_url: width: 120 }}" alt="Video" loading="lazy">
              {% endif %}
              <svg class="pdp__thumb-play" width="20" height="20" viewBox="0 0 24 24" fill="#fff"><polygon points="5 3 19 12 5 21"/></svg>
            </button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- ═══ INFO DEL PRODUCTO ═══ -->
  <div class="pdp__info">

    <!-- Header: tipo | título + share/wishlist -->
    <div class="pdp__header">
      <div>
        {% if product.type != blank %}
          <span class="pdp__type">{{ product.type }}</span>
        {% endif %}
        <h1 class="pdp__title">{{ product.title }}</h1>
      </div>
      <div class="pdp__actions-top">
        <button class="pdp__icon-btn" id="pdp-share" aria-label="Compartir">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        </button>
      </div>
    </div>

    <!-- Rating (estrellas + reseñas locales) -->
    {%- if reviews_count > 0 -%}
      <div class="pdp__meta">
        <a href="#pdp-reviews" class="pdp__rating">
          {%- render 'saluva-stars', rating: reviews_avg, size: 18 -%}
          <span class="pdp__rating-count">{{ reviews_avg | round: 1 }} · {{ reviews_count }} {% if reviews_count == 1 %}reseña{% else %}reseñas{% endif %}</span>
        </a>
      </div>
    {%- endif -%}

    <!-- Precio -->
    <div class="pdp__price-row">
      <span class="pdp__price" id="pdp-price">{{ current_variant.price | money }}</span>
      {% if current_variant.compare_at_price > current_variant.price %}
        <span class="pdp__compare" id="pdp-compare">{{ current_variant.compare_at_price | money }}</span>
      {% endif %}
    </div>
    {% if current_variant.compare_at_price > current_variant.price %}
      {% assign discount_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price %}
      {% assign savings = current_variant.compare_at_price | minus: current_variant.price %}
      <div class="pdp__savings" id="pdp-savings">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        <span>{{ discount_pct }}% OFF — Ahorras {{ savings | money }}</span>
      </div>
    {% endif %}

    <!-- Variantes -->
    {% if product.variants.size > 1 %}
      {% for option in product.options_with_values %}
        {%- assign option_index = forloop.index0 -%}
        <div class="pdp__option">
          <label class="pdp__option-label">{{ option.name }}: <strong id="pdp-option-{{ option_index }}-selected">{{ option.selected_value }}</strong></label>
          <div class="pdp__option-values">
            {% for value in option.values %}
              {%- comment -%} Buscar la imagen de la variante asociada a este valor {%- endcomment -%}
              {%- assign value_image = null -%}
              {%- for variant in product.variants -%}
                {%- if variant.options[option_index] == value and variant.image != blank -%}
                  {%- assign value_image = variant.image -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              <button
                class="pdp__option-btn{% if value_image %} pdp__option-btn--image{% endif %}{% if value == option.selected_value %} active{% endif %}"
                data-option-index="{{ option_index }}"
                data-value="{{ value }}"
                title="{{ value | escape }}"
              >
                {%- if value_image -%}
                  <img class="pdp__option-img" src="{{ value_image | image_url: width: 120 }}" alt="{{ value | escape }}" loading="lazy" width="60" height="60">
                {%- endif -%}
                <span class="pdp__option-text">{{ value }}</span>
              </button>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    {% endif %}

    <!-- Cantidad + Agregar (desktop) — ahora justo debajo del precio/variantes, antes de la descripción -->
    <div class="pdp__add-row pdp__add-row--desktop">
      {% form 'product', product, id: 'pdp-form-desktop' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}" id="pdp-variant-id-desktop">
        <div class="pdp__qty">
          <button type="button" class="qty-btn pdp__qty-btn" data-action="minus" aria-label="Menos">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <input type="number" name="quantity" value="1" min="1" class="pdp__qty-input" onwheel="this.blur()">
          <button type="button" class="qty-btn pdp__qty-btn" data-action="plus" aria-label="Más">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
        </div>
        <button type="submit" class="btn btn--primary pdp__add-btn product-add-btn" {% unless current_variant.available %}disabled{% endunless %}>
          {% if current_variant.available %}Agregar al Carrito{% else %}Agotado{% endif %}
        </button>
      {% endform %}
    </div>

    {%- comment -%} ── Acordeones de información del producto (metafields namespace "custom") ── {%- endcomment -%}
    {%- liquid
      assign acc_titles = 'Datos curiosos,Descripción,Especificaciones,Qué incluye' | split: ','
      assign acc_keys = 'datos_curiosos,descripcion,especificaciones,que_incluye' | split: ','
    -%}
    <div class="pdp__accordion" id="pdp-accordion">
      {%- for i in (0..3) -%}
        {%- assign acc_key = acc_keys[i] -%}
        {%- assign acc_mf = product.metafields.custom[acc_key] -%}
        {%- assign use_desc_fallback = false -%}
        {%- if acc_key == 'descripcion' and acc_mf == blank and product.description != blank -%}
          {%- assign use_desc_fallback = true -%}
        {%- endif -%}
        {%- if acc_mf != blank or use_desc_fallback -%}
          <details class="pdp__acc-item"{% if i == 0 %} open{% endif %}>
            <summary class="pdp__acc-head">
              <span class="pdp__acc-title">{{ acc_titles[i] }}</span>
              <svg class="pdp__acc-chevron" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="pdp__acc-body rte">
              {%- if use_desc_fallback -%}{{ product.description }}{%- else -%}{{ acc_mf | metafield_tag }}{%- endif -%}
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{%- comment -%}
  Vista de producto simplificada:
  - Bloques ¿Por qué elegirla? / ¿Qué contiene? / ¿Cómo tomarla? removidos
  - Los reels de video ahora viven en la sección "saluva-product-reels"
    (configurable desde templates/product.json)
{%- endcomment -%}

<!-- ═══ SECCIÓN DE VALORACIONES Y COMENTARIOS (locales) ═══ -->
<section class="pdp-reviews" id="pdp-reviews">
  <div class="container">
    <div class="pdp-reviews__header">
      <h2 class="pdp-reviews__title">Reseñas de clientes</h2>
    </div>

    {%- if reviews_count > 0 -%}
      <div class="pdp-reviews__summary">
        <div class="pdp-reviews__avg">
          <span class="pdp-reviews__avg-num">{{ reviews_avg | round: 1 }}</span>
          {%- render 'saluva-stars', rating: reviews_avg, size: 22 -%}
          <span class="pdp-reviews__avg-count">{{ reviews_count }} {% if reviews_count == 1 %}reseña{% else %}reseñas{% endif %}</span>
        </div>
        <div class="pdp-reviews__dist">
          {%- assign dist_counts = star5 | append: '|' | append: star4 | append: '|' | append: star3 | append: '|' | append: star2 | append: '|' | append: star1 | split: '|' -%}
          {%- for n in (1..5) reversed -%}
            {%- assign di = 5 | minus: n -%}
            {%- assign dc = dist_counts[di] | times: 1 -%}
            {%- assign dpct = dc | times: 100 | divided_by: reviews_count -%}
            <div class="pdp-reviews__dist-row">
              <span class="pdp-reviews__dist-label">{{ n }}★</span>
              <span class="pdp-reviews__dist-track"><span class="pdp-reviews__dist-bar" style="width: {{ dpct }}%;"></span></span>
              <span class="pdp-reviews__dist-num">{{ dc }}</span>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <div class="pdp-reviews__list">
        {%- for r in reviews -%}
          {%- assign rrating = r.estrellas.value | default: 0 -%}
          {%- assign rimg = r.foto.value -%}
          {%- assign rverified = r.verificado.value -%}
          <article class="pdp-review-card{% if rverified %} pdp-review-card--owner{% endif %}">
            <div class="pdp-review-card__header">
              <span class="pdp-review-card__name">
                {{ r.autor.value | default: 'Cliente' }}
                {%- if rverified -%}<span class="pdp-review-card__badge">✓ Verificado</span>{%- endif -%}
              </span>
              {%- if r.fecha.value -%}<span class="pdp-review-card__date">{{ r.fecha.value | date: '%d %b %Y' }}</span>{%- endif -%}
            </div>
            <div class="pdp-review-card__stars">{%- render 'saluva-stars', rating: rrating, size: 15 -%}</div>
            {%- if r.texto.value != blank -%}<p class="pdp-review-card__text">{{ r.texto.value }}</p>{%- endif -%}
            {%- if rimg -%}
              <div class="pdp-review-card__image" data-review-img="{{ rimg | image_url: width: 1200 }}" role="button" tabindex="0" aria-label="Ampliar imagen de la reseña">
                <img src="{{ rimg | image_url: width: 400 }}" alt="Foto de {{ r.autor.value | default: 'cliente' | escape }}" loading="lazy">
              </div>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="pdp-reviews__empty">Aún no hay reseñas para este producto.</p>
    {%- endif -%}
  </div>
</section>

<!-- ═══ PRODUCTOS RECOMENDADOS ═══ -->
{% assign current_product = product %}
{% assign related_products_list = recommendations.products %}
{% if related_products_list == blank or related_products_list.size == 0 %}
  {% assign related_products_list = collections.all.products %}
{% endif %}

<section class="pdp-related" id="related-products">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-header__label">Descubre más</span>
      <h2 class="section-header__title">Productos que te pueden interesar</h2>
    </div>
    <div class="pdp-related__grid">
      {% assign shown = 0 %}
      {% for p in related_products_list %}
        {% if p.id != current_product.id and shown < 4 and p.available %}
          <a href="{{ p.url }}" class="pdp-related__card">
            <div class="pdp-related__card-img">
              {% if p.featured_image %}
                <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.featured_image.alt | default: p.title }}" loading="lazy">
              {% endif %}
            </div>
            <div class="pdp-related__card-info">
              {% if p.type != blank %}
                <span class="pdp-related__card-type">{{ p.type }}</span>
              {% endif %}
              <h3 class="pdp-related__card-title">{{ p.title }}</h3>
              <div class="pdp-related__card-price">
                <span>{{ p.price | money }}</span>
                {% if p.compare_at_price > p.price %}
                  <span class="pdp-related__card-compare">{{ p.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>
          </a>
          {% assign shown = shown | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══ BARRA STICKY MOBILE: Cantidad + Agregar + Pagar ═══ -->
<div class="pdp__sticky-bar" id="pdp-sticky-bar">
  {% form 'product', product, id: 'pdp-form-mobile' %}
    <input type="hidden" name="id" value="{{ current_variant.id }}" id="pdp-variant-id-mobile">
    <div class="pdp__sticky-row pdp__sticky-row--top">
      <div class="pdp__qty pdp__qty--sticky">
        <button type="button" class="qty-btn pdp__qty-btn" data-action="minus" aria-label="Menos">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <input type="number" name="quantity" value="1" min="1" class="pdp__qty-input" onwheel="this.blur()">
        <button type="button" class="qty-btn pdp__qty-btn" data-action="plus" aria-label="Más">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      </div>
      <button type="submit" class="btn btn--primary pdp__add-btn pdp__add-btn--sticky product-add-btn" {% unless current_variant.available %}disabled{% endunless %}>
        {% if current_variant.available %}Agregar al Carrito{% else %}Agotado{% endif %}
      </button>
    </div>
  {% endform %}
  <a href="/checkout" class="pdp__sticky-pay" id="pdp-sticky-pay" aria-label="Pagar ahora">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
    <span>PAGAR</span>
    <span class="pdp__sticky-pay-count" id="pdp-sticky-pay-count">0</span>
  </a>
</div>

<!-- ═══ BOTÓN FLOTANTE WHATSAPP — COMPRAR CONTRAENTREGA ═══ -->
<a
  href="https://wa.me/{{ section.settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}?text={{ section.settings.whatsapp_message | url_encode }}%20{{ product.title | url_encode }}"
  class="pdp__whatsapp"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="{{ section.settings.whatsapp_label | default: 'Comprar contraentrega' | escape }}"
>
  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    <circle cx="8.5" cy="11.7" r="1.05" fill="#fff" stroke="none"/>
    <circle cx="12" cy="11.7" r="1.05" fill="#fff" stroke="none"/>
    <circle cx="15.5" cy="11.7" r="1.05" fill="#fff" stroke="none"/>
  </svg>
  <span class="pdp__whatsapp-text">{{ section.settings.whatsapp_label | default: 'Comprar contraentrega' }}</span>
</a>

<!-- Lightbox de imágenes con zoom -->
<div class="pdp-lightbox" id="pdp-lightbox" aria-hidden="true" role="dialog" aria-label="Vista ampliada">
  <button class="pdp-lightbox__close" id="pdp-lightbox-close" aria-label="Cerrar">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <button class="pdp-lightbox__nav pdp-lightbox__nav--prev" id="pdp-lightbox-prev" aria-label="Anterior">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="pdp-lightbox__nav pdp-lightbox__nav--next" id="pdp-lightbox-next" aria-label="Siguiente">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <div class="pdp-lightbox__stage" id="pdp-lightbox-stage">
    <img class="pdp-lightbox__img" id="pdp-lightbox-img" alt="" draggable="false">
  </div>
  <span class="pdp-lightbox__counter" id="pdp-lightbox-counter"></span>
  <span class="pdp-lightbox__hint">Doble clic / rueda para zoom · Arrastra para mover · ESC para cerrar</span>
</div>

<!-- Variant data for JS -->
<script type="application/json" id="pdp-variants-json">
  {{ product.variants | json }}
</script>

{% schema %}
{
  "name": "Producto Principal",
  "settings": [
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Número de WhatsApp",
      "info": "Con código de país. Ej: 573001234567",
      "default": "573001234567"
    },
    {
      "type": "text",
      "id": "whatsapp_label",
      "label": "Texto del botón de WhatsApp",
      "default": "Comprar contraentrega"
    },
    {
      "type": "text",
      "id": "whatsapp_message",
      "label": "Mensaje predeterminado",
      "info": "Se le agrega el nombre del producto automáticamente",
      "default": "Hola, quiero comprar CONTRAENTREGA:"
    }
  ]
}
{% endschema %}

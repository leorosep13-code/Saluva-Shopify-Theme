<section id="aprende" class="aprende-section">
  <div class="container">
    <div class="section-header section-header--center anim-flip">
      <span class="section-header__label text-secondary">{{ section.settings.label }}</span>
      <h2 class="section-header__title">{{ section.settings.title }}</h2>
      <p class="section-header__desc">{{ section.settings.description }}</p>
    </div>

    <!-- Filtros por tipo -->
    <div class="aprende-filters" id="aprende-filters">
      <button class="tienda-filter active" data-filter="all">Todos</button>
      <button class="tienda-filter" data-filter="ebook">Ebooks</button>
      <button class="tienda-filter" data-filter="video">Videos</button>
      <button class="tienda-filter" data-filter="plantilla">Plantillas</button>
      <button class="tienda-filter" data-filter="curso">Cursos</button>
    </div>

    <!-- Recurso Destacado -->
    {% for block in section.blocks %}
      {% if block.type == 'featured_resource' %}
        <div class="aprende-featured anim-slide-right" {{ block.shopify_attributes }}>
          <div class="aprende-featured__img-wrap">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 600 }}"
                   alt="{{ block.settings.title }}"
                   class="aprende-featured__img"
                   loading="lazy">
            {% else %}
              <div class="aprende-featured__placeholder">
                <span>⭐</span>
              </div>
            {% endif %}
          </div>
          <div class="aprende-featured__content">
            <span class="digital-card__tag" style="background: var(--color-accent);">DESTACADO</span>
            <h3 class="aprende-featured__title">{{ block.settings.title }}</h3>
            <p class="aprende-featured__desc">{{ block.settings.description }}</p>
            <div class="aprende-featured__footer">
              <span class="digital-card__price">
                {% if block.settings.price == 0 %}Gratis{% else %}{{ block.settings.price | times: 100 | money }}{% endif %}
              </span>
              <a href="{{ block.settings.url }}" class="btn btn--primary btn--md">
                {% if block.settings.price == 0 %}Descargar{% else %}Comprar{% endif %}
              </a>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}

    <!-- Grid de productos digitales -->
    <div class="aprende-grid">
      {% assign card_idx = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'digital_product' %}
          <div class="digital-card digital-card--vertical anim-bounce-up"
               data-type="{{ block.settings.content_type }}"
               data-modal="digital-modal-{{ card_idx }}"
               data-delay="{{ card_idx | times: 100 }}"
               {{ block.shopify_attributes }}>
            <div class="digital-card__image-wrap">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 480 }}"
                     alt="{{ block.settings.title }}"
                     class="digital-card__image"
                     loading="lazy">
              {% else %}
                <div class="digital-card__image-placeholder"
                     style="background: linear-gradient(135deg, {{ block.settings.color_start }}33, {{ block.settings.color_end }}22);">
                  <span>{{ block.settings.emoji }}</span>
                </div>
              {% endif %}

              {%- comment -%} Icono segun tipo de contenido {%- endcomment -%}
              <span class="digital-card__type-icon">
                {% case block.settings.content_type %}
                  {% when 'ebook' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                  {% when 'video' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  {% when 'plantilla' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                  {% when 'curso' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                {% endcase %}
              </span>

              {% if block.settings.content_type == 'video' %}
                <div class="digital-card__play-overlay">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </div>
              {% endif %}
            </div>
            <div class="digital-card__content">
              <div class="digital-card__meta">
                {% if block.settings.tag != blank %}
                  <span class="digital-card__tag {% if block.settings.price == 0 %}digital-card__tag--free{% endif %}">
                    {{ block.settings.tag }}
                  </span>
                {% endif %}
                <span class="digital-card__type">{{ block.settings.type_label }}</span>
              </div>
              <h3 class="digital-card__title">{{ block.settings.title }}</h3>
              <p class="digital-card__desc">{{ block.settings.description }}</p>
              <div class="digital-card__footer">
                <span class="digital-card__price {% if block.settings.price == 0 %}text-primary{% endif %}">
                  {% if block.settings.price == 0 %}Gratis{% else %}{{ block.settings.price | times: 100 | money }}{% endif %}
                </span>
                <a href="{{ block.settings.url }}" class="btn btn--sm {% if block.settings.price == 0 %}btn--primary{% else %}btn--secondary{% endif %}">
                  {% if block.settings.price == 0 %}Descargar{% else %}Comprar{% endif %}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </div>
          </div>

          {%- comment -%} Modal para cada producto digital {%- endcomment -%}
          <div class="digital-modal" id="digital-modal-{{ card_idx }}" aria-hidden="true">
            <div class="digital-modal__backdrop"></div>
            <div class="digital-modal__card">
              <button class="digital-modal__close" aria-label="Cerrar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
              <div class="digital-modal__img-wrap">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 800 }}"
                       alt="{{ block.settings.title }}"
                       class="digital-modal__img"
                       loading="lazy">
                {% else %}
                  <div class="digital-modal__placeholder"
                       style="background: linear-gradient(135deg, {{ block.settings.color_start }}33, {{ block.settings.color_end }}22);">
                    <span>{{ block.settings.emoji }}</span>
                  </div>
                {% endif %}
              </div>
              <div class="digital-modal__content">
                <h3 class="digital-modal__title">{{ block.settings.title }}</h3>
                <p class="digital-modal__desc">{{ block.settings.modal_description | default: block.settings.description }}</p>
                {% if block.settings.includes != blank %}
                  <div class="digital-modal__includes">
                    <h4>Lo que incluye:</h4>
                    {% assign items = block.settings.includes | split: '|' %}
                    <ul>
                      {% for item in items %}
                        {% if item != blank %}
                          <li>{{ item }}</li>
                        {% endif %}
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
                <div class="digital-modal__footer">
                  <span class="digital-card__price" style="font-size: 24px;">
                    {% if block.settings.price == 0 %}Gratis{% else %}{{ block.settings.price | times: 100 | money }}{% endif %}
                  </span>
                  <a href="{{ block.settings.url }}" class="btn btn--primary btn--lg">
                    {% if block.settings.price == 0 %}Descargar Gratis{% else %}Comprar Ahora{% endif %}
                  </a>
                </div>
              </div>
            </div>
          </div>

          {% assign card_idx = card_idx | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var filters = document.querySelectorAll('#aprende-filters .tienda-filter');
    var cards = document.querySelectorAll('.aprende-grid .digital-card');
    filters.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var filter = btn.dataset.filter;
        filters.forEach(function(f) { f.classList.remove('active'); });
        btn.classList.add('active');
        cards.forEach(function(card) {
          if (filter === 'all' || card.dataset.type === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>

{% schema %}
{
  "name": "Crece con Nosotros",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "CRECE CON NOSOTROS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Productos Digitales"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripcion",
      "default": "Guias, recetarios, masterclasses y mas. Aprende a cuidarte desde adentro."
    }
  ],
  "blocks": [
    {
      "type": "featured_resource",
      "name": "Recurso Destacado",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "text", "id": "title", "label": "Titulo", "default": "Guia Completa de Bienestar Femenino" },
        { "type": "textarea", "id": "description", "label": "Descripcion", "default": "Nuestra guia mas completa con todo lo que necesitas saber sobre suplementacion, nutricion y bienestar." },
        { "type": "number", "id": "price", "label": "Precio (0 = gratis)", "default": 0 },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    },
    {
      "type": "digital_product",
      "name": "Producto Digital",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji", "default": "📖" },
        { "type": "image_picker", "id": "image", "label": "Imagen (reemplaza emoji)" },
        { "type": "text", "id": "title", "label": "Titulo", "default": "Guia de Bienestar" },
        { "type": "text", "id": "type_label", "label": "Tipo", "default": "PDF · 45 paginas" },
        { "type": "text", "id": "tag", "label": "Etiqueta", "default": "Gratis" },
        {
          "type": "select",
          "id": "content_type",
          "label": "Tipo de contenido",
          "options": [
            { "value": "ebook", "label": "Ebook" },
            { "value": "video", "label": "Video" },
            { "value": "plantilla", "label": "Plantilla" },
            { "value": "curso", "label": "Curso" }
          ],
          "default": "ebook"
        },
        { "type": "textarea", "id": "description", "label": "Descripcion corta", "default": "Todo lo que necesitas saber sobre bienestar" },
        { "type": "textarea", "id": "modal_description", "label": "Descripcion completa (modal)", "default": "Descripcion detallada del producto digital." },
        { "type": "text", "id": "includes", "label": "Lo que incluye (separar con |)", "default": "45 paginas de contenido|Recetas exclusivas|Tips de expertos|Acceso de por vida" },
        { "type": "number", "id": "price", "label": "Precio (0 = gratis)", "default": 0 },
        { "type": "url", "id": "url", "label": "URL de descarga/compra" },
        { "type": "color", "id": "color_start", "label": "Color fondo inicio", "default": "#d2a4f3" },
        { "type": "color", "id": "color_end", "label": "Color fondo fin", "default": "#a4c93b" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Crece con Nosotros",
      "blocks": [
        { "type": "featured_resource", "settings": { "title": "Guia Completa de Bienestar Femenino", "description": "Nuestra guia mas completa con todo lo que necesitas saber sobre suplementacion y bienestar.", "price": 0 } },
        { "type": "digital_product", "settings": { "emoji": "📖", "title": "Guia de Bienestar Femenino", "type_label": "PDF · 45 paginas", "tag": "Gratis", "content_type": "ebook", "description": "Todo lo que necesitas saber sobre suplementacion consciente", "price": 0 } },
        { "type": "digital_product", "settings": { "emoji": "🍽️", "title": "Recetario Saludable Vol. 1", "type_label": "PDF · 30 recetas", "content_type": "ebook", "description": "Recetas nutritivas para cada momento del dia", "price": 29900 } },
        { "type": "digital_product", "settings": { "emoji": "🎬", "title": "Masterclass: Equilibrio Hormonal", "type_label": "Video · 90 min", "content_type": "video", "description": "Aprende a balancear tus hormonas naturalmente", "price": 49900 } },
        { "type": "digital_product", "settings": { "emoji": "📅", "title": "Planificador de Bienestar 2026", "type_label": "PDF interactivo", "tag": "Nuevo", "content_type": "plantilla", "description": "Organiza tu rutina de bienestar mes a mes", "price": 19900 } },
        { "type": "digital_product", "settings": { "emoji": "🎓", "title": "Curso: Nutricion Consciente", "type_label": "Video · 6 modulos", "tag": "Nuevo", "content_type": "curso", "description": "Aprende a alimentarte de forma consciente e intuitiva", "price": 89900 } },
        { "type": "digital_product", "settings": { "emoji": "📊", "title": "Plantilla de Seguimiento", "type_label": "Excel · Interactivo", "content_type": "plantilla", "description": "Lleva el control de tus habitos y suplementos", "price": 0, "tag": "Gratis" } }
      ]
    }
  ]
}
{% endschema %}

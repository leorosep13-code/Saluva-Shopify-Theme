{%- comment -%}
  MISOJI — Reseñas de clientes (locales, metaobjetos custom.resenas).
  Extraída de main-product para poder ordenarla libremente en product.json.
{%- endcomment -%}

{%- liquid
  assign reviews = product.metafields.custom.resenas.value
  assign reviews_count = 0
  assign reviews_total = 0
  assign star5 = 0
  assign star4 = 0
  assign star3 = 0
  assign star2 = 0
  assign star1 = 0
  if reviews
    assign reviews_count = reviews.size
    for r in reviews
      assign rv = r.estrellas.value | default: 0 | round
      assign reviews_total = reviews_total | plus: rv
      case rv
        when 5
          assign star5 = star5 | plus: 1
        when 4
          assign star4 = star4 | plus: 1
        when 3
          assign star3 = star3 | plus: 1
        when 2
          assign star2 = star2 | plus: 1
        else
          assign star1 = star1 | plus: 1
      endcase
    endfor
  endif
  assign reviews_avg = 0
  if reviews_count > 0
    assign reviews_avg = reviews_total | times: 1.0 | divided_by: reviews_count
  endif
-%}

<section class="pdp-reviews" id="pdp-reviews">
  <div class="container">
    <div class="pdp-reviews__header">
      <h2 class="pdp-reviews__title">Reseñas de clientes</h2>
    </div>

    {%- if reviews_count > 0 -%}
      <div class="pdp-reviews__summary">
        <div class="pdp-reviews__avg">
          <div class="pdp-reviews__avg-top">
            {%- render 'saluva-stars', rating: reviews_avg, size: 26 -%}
            <span class="pdp-reviews__avg-num">{{ reviews_avg | round: 2 }} de 5</span>
          </div>
          <span class="pdp-reviews__avg-count">Basado en {{ reviews_count }} {% if reviews_count == 1 %}reseña{% else %}reseñas{% endif %}</span>
        </div>
        <div class="pdp-reviews__dist">
          {%- assign dist_counts = star5 | append: '|' | append: star4 | append: '|' | append: star3 | append: '|' | append: star2 | append: '|' | append: star1 | split: '|' -%}
          {%- for n in (1..5) reversed -%}
            {%- assign di = 5 | minus: n -%}
            {%- assign dc = dist_counts[di] | times: 1 -%}
            {%- assign dpct = dc | times: 100 | divided_by: reviews_count -%}
            <div class="pdp-reviews__dist-row">
              <span class="pdp-reviews__dist-stars">{%- render 'saluva-stars', rating: n, size: 15 -%}</span>
              <span class="pdp-reviews__dist-track"><span class="pdp-reviews__dist-bar" style="width: {{ dpct }}%;"></span></span>
              <span class="pdp-reviews__dist-num">{{ dc }}</span>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <div class="pdp-reviews__list">
        {%- for r in reviews -%}
          {%- assign rrating = r.estrellas.value | default: 0 -%}
          {%- assign rimg = r.foto.value -%}
          {%- assign rverified = r.verificado.value -%}
          <article class="pdp-review-card{% if rverified %} pdp-review-card--owner{% endif %}">
            <div class="pdp-review-card__header">
              <span class="pdp-review-card__name">
                {{ r.autor.value | default: 'Cliente' }}
                {%- if rverified -%}<span class="pdp-review-card__badge">✓ Verificado</span>{%- endif -%}
              </span>
              {%- if r.fecha.value -%}<span class="pdp-review-card__date">{{ r.fecha.value | date: '%d %b %Y' }}</span>{%- endif -%}
            </div>
            <div class="pdp-review-card__stars">{%- render 'saluva-stars', rating: rrating, size: 15 -%}</div>
            {%- if r.texto.value != blank -%}<p class="pdp-review-card__text">{{ r.texto.value }}</p>{%- endif -%}
            {%- if rimg -%}
              <div class="pdp-review-card__image" data-review-img="{{ rimg | image_url: width: 1200 }}" role="button" tabindex="0" aria-label="Ampliar imagen de la reseña">
                <img src="{{ rimg | image_url: width: 400 }}" alt="Foto de {{ r.autor.value | default: 'cliente' | escape }}" loading="lazy">
              </div>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="pdp-reviews__empty">Aún no hay reseñas para este producto.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Reseñas de clientes",
  "settings": [
    { "type": "paragraph", "content": "Las reseñas se gestionan con metaobjetos en el metafield del producto «custom.resenas»." }
  ],
  "presets": [
    { "name": "Reseñas de clientes" }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}

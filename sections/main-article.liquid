<article class="article-page">
  <div class="article-page__hero">
    {% if article.image != blank %}
      <img
        src="{{ article.image | image_url: width: 1600 }}"
        alt="{{ article.image.alt | default: article.title }}"
        class="article-page__hero-img"
        loading="eager">
      <div class="article-page__hero-overlay"></div>
    {% endif %}
    <div class="article-page__hero-inner container">
      <nav class="article-page__breadcrumbs" aria-label="Navegacion">
        <a href="/">Inicio</a>
        <span>/</span>
        <a href="{{ blog.url }}">{{ blog.title }}</a>
        <span>/</span>
        <span>{{ article.title }}</span>
      </nav>
      <h1 class="article-page__title">{{ article.title }}</h1>
      <div class="article-page__meta">
        <span class="article-page__author">{{ article.author }}</span>
        <span class="article-page__dot">·</span>
        <span class="article-page__date">{{ article.published_at | date: '%d %b %Y' }}</span>
        {% if article.tags.size > 0 %}
          <span class="article-page__dot">·</span>
          <span class="article-page__tags">
            {% for tag in article.tags %}
              <span class="article-page__tag">{{ tag }}</span>
            {% endfor %}
          </span>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="container">
    <div class="article-page__content rte">
      {{ article.content }}
    </div>

    <div class="article-page__share">
      <span class="article-page__share-label">Compartir:</span>
      <a href="https://api.whatsapp.com/send?text={{ article.title | url_encode }}%20{{ shop.url | append: article.url | url_encode }}" target="_blank" rel="noopener" aria-label="Compartir en WhatsApp">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 21.785h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/></svg>
      </a>
      <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url | append: article.url | url_encode }}" target="_blank" rel="noopener" aria-label="Compartir en Facebook">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12S0 5.446 0 12.073c0 5.989 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073"/></svg>
      </a>
    </div>

    {% if blog.comments_enabled? %}
      <section class="article-page__comments">
        <h2 class="article-page__comments-title">
          {{ article.comments_count }} {% if article.comments_count == 1 %}Comentario{% else %}Comentarios{% endif %}
        </h2>

        {% if article.comments.size > 0 %}
          <ul class="article-page__comments-list">
            {% for comment in article.comments %}
              <li class="article-page__comment">
                <div class="article-page__comment-meta">
                  <strong>{{ comment.author }}</strong>
                  <span>{{ comment.created_at | date: '%d %b %Y' }}</span>
                </div>
                <p>{{ comment.content }}</p>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

        {% form 'new_comment', article %}
          <h3 class="article-page__comment-form-title">Deja tu comentario</h3>
          {% if form.errors %}
            <p class="article-page__form-error">
              Hubo un error: {{ form.errors | default_errors }}
            </p>
          {% endif %}
          {% if form.posted_successfully? %}
            <p class="article-page__form-ok">
              Tu comentario fue publicado.
            </p>
          {% endif %}
          <div class="article-page__form-row">
            <input type="text" name="comment[author]" placeholder="Tu nombre" required>
          </div>
          <div class="article-page__form-row">
            <input type="email" name="comment[email]" placeholder="Tu email" required>
          </div>
          <div class="article-page__form-row">
            <textarea name="comment[body]" rows="4" placeholder="Tu comentario..." required></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--md">Publicar comentario</button>
        {% endform %}
      </section>
    {% endif %}
  </div>
</article>

{% schema %}
{
  "name": "Articulo Principal",
  "settings": []
}
{% endschema %}

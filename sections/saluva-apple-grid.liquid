{%- comment -%}
  Galería de imágenes en formato grande tipo Apple.
  Cada tarjeta es una imagen con un overlay inferior (texto + botón al producto).
{%- endcomment -%}

<section id="apple-grid" class="apple-grid">
  <div class="container">
    {%- if section.settings.label != blank or section.settings.title != blank -%}
      <div class="section-header section-header--center anim-flip">
        {%- if section.settings.label != blank -%}
          <span class="section-header__label">{{ section.settings.label }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="section-header__title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="apple-grid__layout anim-stagger">
      {%- for block in section.blocks -%}
        {%- assign card_class = 'apple-grid__card' -%}
        {%- if block.settings.wide -%}{%- assign card_class = card_class | append: ' apple-grid__card--wide' -%}{%- endif -%}

        <div class="{{ card_class }}" {{ block.shopify_attributes }}>
          <div class="apple-grid__card-bg">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1600 }}"
                   alt="{{ block.settings.image.alt | default: block.settings.caption | default: 'Producto misoji' }}"
                   class="apple-grid__card-img"
                   loading="lazy"
                   width="1600">
            {%- else -%}
              <div class="apple-grid__card-placeholder">✨</div>
            {%- endif -%}
          </div>

          {%- if block.settings.caption != blank or block.settings.cta_url != blank -%}
            <div class="apple-grid__card-overlay">
              {%- if block.settings.caption != blank -%}
                <p class="apple-grid__card-caption">{{ block.settings.caption }}</p>
              {%- endif -%}
              {%- if block.settings.cta_url != blank -%}
                <a href="{{ block.settings.cta_url }}" class="apple-grid__card-btn">
                  {{ block.settings.cta_text | default: 'Ver producto' }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Galería tipo Apple",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta superior",
      "default": "MÁS VENDIDOS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Lo más amado por nuestra comunidad"
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "card",
      "name": "Tarjeta",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen (recomendado alta resolución)"
        },
        {
          "type": "checkbox",
          "id": "wide",
          "label": "Ancho completo",
          "default": false
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Texto inferior (opcional)",
          "default": "Induction Device"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Texto del botón",
          "default": "Ver producto"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "URL del producto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Galería tipo Apple misoji",
      "blocks": [
        { "type": "card", "settings": { "caption": "Induction Device", "cta_text": "Ver producto" } },
        { "type": "card", "settings": { "caption": "Aurora Series", "cta_text": "Ver producto" } }
      ]
    }
  ]
}
{% endschema %}

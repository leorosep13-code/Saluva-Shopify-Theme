{%- comment -%}
  MISOJI — Tutorial "Fácil como 1, 2, 3"
  Pasos numerados con imagen + título + descripción. Reduce la fricción de uso.
{%- endcomment -%}

<section class="saluva-steps {% if section.settings.bg_aurora %}aurora-bg{% endif %}" id="saluva-steps-{{ section.id }}">
  <div class="container">
    {%- if section.settings.title != blank or section.settings.label != blank -%}
      <div class="section-header section-header--center anim-flip">
        {%- if section.settings.label != blank -%}
          <span class="section-header__label">{{ section.settings.label }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="section-header__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="section-header__desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Preferimos metaobjetos del producto (custom.pasos); si no hay, usamos bloques del editor {%- endcomment -%}
    {%- assign mo_steps = product.metafields.custom.pasos.value | default: product.metafields.saluva.pasos.value -%}
    {%- assign use_mo = false -%}
    {%- if mo_steps != blank and mo_steps.size > 0 -%}{%- assign use_mo = true -%}{%- assign steps = mo_steps -%}{%- else -%}{%- assign steps = section.blocks -%}{%- endif -%}

    <div class="saluva-steps__grid anim-stagger">
      {%- for item in steps -%}
        {%- if use_mo -%}
          {%- assign s_img = item.imagen.value -%}
          {%- assign s_title = item.titulo.value -%}
          {%- assign s_text = item.descripcion.value -%}
          {%- assign attrs = '' -%}
        {%- else -%}
          {%- assign s_img = item.settings.image -%}
          {%- assign s_title = item.settings.title -%}
          {%- assign s_text = item.settings.text -%}
          {%- assign attrs = item.shopify_attributes -%}
        {%- endif -%}
        <div class="saluva-steps__card" {{ attrs }}>
          <div class="saluva-steps__media">
            {%- if s_img != blank -%}
              <img src="{{ s_img | image_url: width: 600 }}"
                   alt="{{ s_title | escape }}"
                   class="saluva-steps__img" loading="lazy" width="600" height="600">
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'saluva-steps__placeholder' }}
            {%- endif -%}
            <span class="saluva-steps__num">{{ forloop.index }}</span>
          </div>
          <div class="saluva-steps__body">
            <h3 class="saluva-steps__title">{{ s_title }}</h3>
            {%- if s_text != blank -%}
              <p class="saluva-steps__text">{{ s_text }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Tutorial 1-2-3",
  "settings": [
    { "type": "paragraph", "content": "Los pasos se toman del metafield del producto «custom.pasos» (lista de metaobjetos «paso» con campos imagen, titulo, descripcion). Si el producto no tiene, se usan los bloques de abajo como respaldo." },
    { "type": "text", "id": "label", "label": "Etiqueta superior", "default": "MODO DE USO" },
    { "type": "text", "id": "title", "label": "Título", "default": "Fácil como 1, 2, 3" },
    { "type": "textarea", "id": "description", "label": "Descripción (opcional)", "default": "Resultados profesionales en casa, sin complicaciones." },
    { "type": "checkbox", "id": "bg_aurora", "label": "Fondo Aurora", "default": false }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "step",
      "name": "Paso",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "text", "id": "title", "label": "Título del paso", "default": "Prepara la zona" },
        { "type": "textarea", "id": "text", "label": "Descripción", "default": "Limpia y seca la zona a tratar antes de comenzar." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tutorial 1-2-3",
      "blocks": [
        { "type": "step", "settings": { "title": "Prepara la zona", "text": "Limpia y seca bien el área antes de comenzar para mejores resultados." } },
        { "type": "step", "settings": { "title": "Enciende y elige el nivel", "text": "Selecciona la intensidad según la zona y tu nivel de comodidad." } },
        { "type": "step", "settings": { "title": "Trata el área", "text": "Apoya el dispositivo sobre la piel y desliza lentamente para completar el tratamiento." } }
      ]
    }
  ]
}
{% endschema %}

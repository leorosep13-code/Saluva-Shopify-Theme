<header class="header" id="site-header">
  <div class="header__inner container">
    <a href="/" class="header__logo">
      {% if settings.logo != blank %}
        <img src="{{ settings.logo | image_url: width: 200 }}" alt="misoji Beauty" class="header__logo-img" style="width: {{ settings.logo_width }}px;">
      {% elsif section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="misoji Beauty" class="header__logo-img">
      {% else %}
        <img src="{{ 'logo_misoji.jpeg' | asset_url }}" alt="misoji Beauty" class="header__logo-img header__logo-img--misoji">
      {% endif %}
    </a>

    <nav class="header__nav" id="main-nav">
      <!-- Enlaces fijos de navegación -->
      <div class="header__nav-item">
        <a href="/" class="header__nav-link nav-anchor" data-section="landing">Inicio</a>
      </div>
      <div class="header__nav-item">
        <a href="/collections/ofertas" class="header__nav-link nav-anchor" data-section="ofertas">Ofertas</a>
      </div>

      {% comment %} Bloques dinámicos del customizer (Productos con mega menu de categorías) {% endcomment %}
      {% for block in section.blocks %}
        {% if block.type == 'nav_link' %}
          <div class="header__nav-item {% if block.settings.has_megamenu %}header__nav-item--mega{% endif %}">
            {%- if block.settings.has_megamenu -%}
              <a href="#" class="header__nav-link" aria-haspopup="true" aria-expanded="false">
                {{ block.settings.label }}
                <svg class="header__nav-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </a>
            {%- else -%}
              <a href="{{ block.settings.url }}"
                 class="header__nav-link {% if block.settings.is_anchor %}nav-anchor{% endif %}"
                 {% if block.settings.is_anchor %}data-section="{{ block.settings.anchor_id }}"{% endif %}>
                {{ block.settings.label }}
              </a>
            {%- endif -%}

            {% if block.settings.has_megamenu %}
              <div class="mega-menu" id="mega-menu">
                <div class="mega-menu__inner container">
                  <div class="mega-menu__columns">
                    <div class="mega-menu__col">
                      <h4 class="mega-menu__col-title">{{ block.settings.mega_col1_title }}</h4>
                      {% assign links1 = block.settings.mega_col1_links | split: '|' %}
                      {% for link_text in links1 %}
                        {% assign parts = link_text | split: ':' %}
                        {% if parts.size >= 2 %}
                          <a href="{{ parts[1] }}" class="mega-menu__link">{{ parts[0] }}</a>
                        {% elsif link_text != blank %}
                          <a href="/collections/{{ link_text | handleize }}" class="mega-menu__link">{{ link_text }}</a>
                        {% endif %}
                      {% endfor %}
                    </div>
                    <div class="mega-menu__col">
                      <h4 class="mega-menu__col-title">{{ block.settings.mega_col2_title }}</h4>
                      {% assign links2 = block.settings.mega_col2_links | split: '|' %}
                      {% for link_text in links2 %}
                        {% assign parts = link_text | split: ':' %}
                        {% if parts.size >= 2 %}
                          <a href="{{ parts[1] }}" class="mega-menu__link">{{ parts[0] }}</a>
                        {% elsif link_text != blank %}
                          <a href="/collections/{{ link_text | handleize }}" class="mega-menu__link">{{ link_text }}</a>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      <div class="header__nav-item">
        <a href="/pages/productos-digitales" class="header__nav-link">Productos Digitales</a>
      </div>
      <div class="header__nav-item">
        <a href="/pages/aprende-a-cuidarte" class="header__nav-link">Aprende a Cuidarte</a>
      </div>
    </nav>

    <div class="header__actions">
      <button class="header__action-btn" aria-label="Buscar" id="search-toggle">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <a href="/account" class="header__action-btn" aria-label="Cuenta">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="/cart" class="header__action-btn header__cart" aria-label="Carrito">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <span class="header__cart-count" id="cart-count">{{ cart.item_count }}</span>
      </a>

      <button class="header__hamburger" id="mobile-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- Search Overlay -->
<div class="search-overlay" id="search-overlay" aria-hidden="true">
  <div class="search-overlay__backdrop" id="search-close-backdrop"></div>
  <div class="search-overlay__inner">
    <div class="search-overlay__input-wrap">
      <svg class="search-overlay__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text"
             class="search-overlay__input"
             id="search-input"
             placeholder="Buscar productos..."
             autocomplete="off"
             aria-label="Buscar productos">
    </div>
    <div class="search-overlay__results" id="search-results" style="display:none;"></div>
  </div>
</div>

{% schema %}
{
  "name": "Encabezado",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Enlace de navegacion",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Texto",
          "default": "Inicio"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        },
        {
          "type": "checkbox",
          "id": "is_anchor",
          "label": "Es un ancla en la pagina?",
          "default": true
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "ID de la seccion",
          "default": "landing"
        },
        {
          "type": "checkbox",
          "id": "has_megamenu",
          "label": "Tiene mega menu?",
          "default": false
        },
        {
          "type": "text",
          "id": "mega_col1_title",
          "label": "Mega Menu - Titulo columna 1",
          "default": "POR ZONA"
        },
        {
          "type": "text",
          "id": "mega_col1_links",
          "label": "Mega Menu - Links columna 1 (nombre|nombre)",
          "default": "Rostro|Cuerpo|Cabello|Ojos|Manos y pies"
        },
        {
          "type": "text",
          "id": "mega_col2_title",
          "label": "Mega Menu - Titulo columna 2",
          "default": "POR TECNOLOGIA"
        },
        {
          "type": "text",
          "id": "mega_col2_links",
          "label": "Mega Menu - Links columna 2 (nombre|nombre)",
          "default": "Induction|LED|Microcorriente|Radiofrecuencia|Ultrasonido"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Encabezado Saluva",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "Productos", "url": "/collections/all", "is_anchor": false, "has_megamenu": true } }
      ]
    }
  ]
}
{% endschema %}

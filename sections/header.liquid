<header class="header" id="site-header">
  <div class="header__inner container">
    <a href="/" class="header__logo">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="header__logo-img">
      {% else %}
        <span class="header__logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>

    <nav class="header__nav" id="main-nav">
      {% for block in section.blocks %}
        {% if block.type == 'nav_link' %}
          <a href="{{ block.settings.url }}"
             class="header__nav-link {% if block.settings.is_anchor %}nav-anchor{% endif %}"
             {% if block.settings.is_anchor %}data-section="{{ block.settings.anchor_id }}"{% endif %}>
            {{ block.settings.label }}
          </a>
        {% endif %}
      {% endfor %}
    </nav>

    <div class="header__actions">
      <button class="header__action-btn" aria-label="Buscar" id="search-toggle">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <a href="/account" class="header__action-btn" aria-label="Cuenta">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="/cart" class="header__action-btn header__cart" aria-label="Carrito">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <span class="header__cart-count" id="cart-count">{{ cart.item_count }}</span>
      </a>

      <button class="header__hamburger" id="mobile-toggle" aria-label="Menú">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Encabezado",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Enlace de navegación",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Texto",
          "default": "Inicio"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL",
          "default": "/"
        },
        {
          "type": "checkbox",
          "id": "is_anchor",
          "label": "¿Es un ancla en la página?",
          "default": true
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "ID de la sección",
          "default": "landing"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Encabezado Saluva",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "Inicio", "url": "/", "is_anchor": true, "anchor_id": "landing" } },
        { "type": "nav_link", "settings": { "label": "Tienda", "url": "/collections/all", "is_anchor": true, "anchor_id": "tienda" } },
        { "type": "nav_link", "settings": { "label": "Más Vendidos", "url": "/collections/bestsellers", "is_anchor": true, "anchor_id": "bestsellers" } },
        { "type": "nav_link", "settings": { "label": "Aprende con Nosotros", "url": "/pages/aprende", "is_anchor": true, "anchor_id": "aprende" } },
        { "type": "nav_link", "settings": { "label": "Aprende a Conocerte", "url": "/pages/quiz", "is_anchor": true, "anchor_id": "quiz" } }
      ]
    }
  ]
}
{% endschema %}

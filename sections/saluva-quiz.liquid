<section id="quiz" class="quiz-section">
  <div class="container">
    <!-- Quiz Intro -->
    <div class="quiz-intro anim-zoom" id="quiz-intro">
      <div class="quiz-intro__icon">🔮</div>
      <span class="section-header__label text-secondary">{{ section.settings.label }}</span>
      <h2 class="section-header__title">{{ section.settings.title }}</h2>
      <p class="section-header__desc">{{ section.settings.description }}</p>
      <button class="btn btn--primary btn--lg quiz-start-btn" id="quiz-start">
        Comenzar Quiz
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>

    <!-- Quiz Questions -->
    <div class="quiz-container" id="quiz-container" style="display:none;">
      <!-- Progress bar continua -->
      <div class="quiz-progress-continuous">
        <div class="quiz-progress-continuous__fill" id="quiz-progress-bar" style="width: 0%;"></div>
      </div>
      <span class="quiz-counter" id="quiz-counter">Pregunta 1 de {{ section.blocks | where: 'type', 'question' | size }}</span>

      <!-- Back button -->
      <button class="quiz-back-btn" id="quiz-back" aria-label="Volver a la pregunta anterior">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Atras
      </button>

      {% assign q_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'question' %}
          <div class="quiz-question" id="quiz-q-{{ q_index }}" data-question="{{ q_index }}" style="{% if q_index > 0 %}display:none;{% endif %}" {{ block.shopify_attributes }}>
            <h2 class="quiz-question__title">{{ block.settings.question }}</h2>
            <div class="quiz-options">
              {%- comment -%} Option 1 {%- endcomment -%}
              {% if block.settings.option_1 != blank %}
                <button class="quiz-option"
                        data-question="{{ q_index }}"
                        data-answer="0"
                        data-pts-energia="{{ block.settings.opt1_energia }}"
                        data-pts-belleza="{{ block.settings.opt1_belleza }}"
                        data-pts-inmunidad="{{ block.settings.opt1_inmunidad }}"
                        data-pts-digestion="{{ block.settings.opt1_digestion }}">
                  <span class="quiz-option__emoji">{{ block.settings.opt1_emoji }}</span>
                  <span class="quiz-option__text">{{ block.settings.option_1 }}</span>
                </button>
              {% endif %}

              {%- comment -%} Option 2 {%- endcomment -%}
              {% if block.settings.option_2 != blank %}
                <button class="quiz-option"
                        data-question="{{ q_index }}"
                        data-answer="1"
                        data-pts-energia="{{ block.settings.opt2_energia }}"
                        data-pts-belleza="{{ block.settings.opt2_belleza }}"
                        data-pts-inmunidad="{{ block.settings.opt2_inmunidad }}"
                        data-pts-digestion="{{ block.settings.opt2_digestion }}">
                  <span class="quiz-option__emoji">{{ block.settings.opt2_emoji }}</span>
                  <span class="quiz-option__text">{{ block.settings.option_2 }}</span>
                </button>
              {% endif %}

              {%- comment -%} Option 3 {%- endcomment -%}
              {% if block.settings.option_3 != blank %}
                <button class="quiz-option"
                        data-question="{{ q_index }}"
                        data-answer="2"
                        data-pts-energia="{{ block.settings.opt3_energia }}"
                        data-pts-belleza="{{ block.settings.opt3_belleza }}"
                        data-pts-inmunidad="{{ block.settings.opt3_inmunidad }}"
                        data-pts-digestion="{{ block.settings.opt3_digestion }}">
                  <span class="quiz-option__emoji">{{ block.settings.opt3_emoji }}</span>
                  <span class="quiz-option__text">{{ block.settings.option_3 }}</span>
                </button>
              {% endif %}

              {%- comment -%} Option 4 {%- endcomment -%}
              {% if block.settings.option_4 != blank %}
                <button class="quiz-option"
                        data-question="{{ q_index }}"
                        data-answer="3"
                        data-pts-energia="{{ block.settings.opt4_energia }}"
                        data-pts-belleza="{{ block.settings.opt4_belleza }}"
                        data-pts-inmunidad="{{ block.settings.opt4_inmunidad }}"
                        data-pts-digestion="{{ block.settings.opt4_digestion }}">
                  <span class="quiz-option__emoji">{{ block.settings.opt4_emoji }}</span>
                  <span class="quiz-option__text">{{ block.settings.option_4 }}</span>
                </button>
              {% endif %}
            </div>
          </div>
          {% assign q_index = q_index | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>

    <!-- Quiz Results -->
    <div class="quiz-result" id="quiz-result" style="display:none;">
      <div class="quiz-result__icon" id="quiz-result-icon">✨</div>
      <h2 class="quiz-result__title">Tu Match Perfecto!</h2>
      <h3 class="quiz-result__subtitle text-primary" id="quiz-result-name"></h3>
      <p class="quiz-result__desc" id="quiz-result-desc"></p>
      <div class="quiz-result__products" id="quiz-result-products"></div>
      <div class="quiz-result__actions">
        <button class="btn btn--primary btn--md" id="quiz-share">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          Compartir Resultado
        </button>
        <button class="btn btn--outline btn--md" id="quiz-restart">
          Volver a Intentar
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  window.__quizResults = {
    {% for block in section.blocks %}
      {% if block.type == 'result' %}
        "{{ block.settings.result_key }}": {
          "title": {{ block.settings.result_title | json }},
          "emoji": {{ block.settings.emoji | json }},
          "description": {{ block.settings.result_description | json }},
          "products": [
            {% if block.settings.product_1 != blank %}
              {% assign p1 = block.settings.product_1 %}
              {
                "url": {{ p1.url | json }},
                "title": {{ p1.title | json }},
                "price": {{ p1.price | money | json }},
                "compare_price": {% if p1.compare_at_price > p1.price %}{{ p1.compare_at_price | money | json }}{% else %}""{% endif %},
                "image": {{ p1.featured_image | image_url: width: 400 | json }},
                "available": {{ p1.available | json }}
              },
            {% endif %}
            {% if block.settings.product_2 != blank %}
              {% assign p2 = block.settings.product_2 %}
              {
                "url": {{ p2.url | json }},
                "title": {{ p2.title | json }},
                "price": {{ p2.price | money | json }},
                "compare_price": {% if p2.compare_at_price > p2.price %}{{ p2.compare_at_price | money | json }}{% else %}""{% endif %},
                "image": {{ p2.featured_image | image_url: width: 400 | json }},
                "available": {{ p2.available | json }}
              },
            {% endif %}
          ]
        },
      {% endif %}
    {% endfor %}
  };
</script>


<footer class="footer">
  <div class="container">
    <!-- Newsletter -->
    <div class="footer__newsletter animate-on-scroll">
      <div class="footer__newsletter-content">
        <h3 class="footer__newsletter-title">{{ settings.newsletter_title | default: 'Unete a nuestra comunidad' }}</h3>
        <p class="footer__newsletter-desc">{{ settings.newsletter_description | default: 'Recibe tips de bienestar, ofertas exclusivas y novedades.' }}</p>
      </div>
      <div class="footer__newsletter-form">
        {% form 'customer', id: 'newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__newsletter-input-wrap">
            <input type="email"
                   name="contact[email]"
                   placeholder="Tu correo electronico"
                   required
                   aria-label="Correo electronico para newsletter"
                   class="footer__newsletter-input">
            <button type="submit" class="footer__newsletter-btn">
              SUSCRIBIRSE
            </button>
          </div>
        {% endform %}
      </div>
    </div>

    <div class="footer__grid">
      <div class="footer__brand">
        <div class="footer__logo">{{ shop.name }}</div>
        <p class="footer__tagline">{{ section.settings.tagline }}</p>
        <div class="footer__social">
          {% if settings.social_instagram != blank %}
            <a href="{{ settings.social_instagram }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {% endif %}
          {% if settings.social_facebook != blank %}
            <a href="{{ settings.social_facebook }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_tiktok != blank %}
            <a href="{{ settings.social_tiktok }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13v-3.5a6.37 6.37 0 0 0-.88-.07A6.33 6.33 0 0 0 3.16 15.3a6.33 6.33 0 0 0 10.86 4.43v-7.1a8.16 8.16 0 0 0 4.77 1.52V10.7a4.85 4.85 0 0 1-.8.06 4.82 4.82 0 0 1-.4-4.07z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_twitter != blank %}
            <a href="{{ settings.social_twitter }}" class="footer__social-link" aria-label="Twitter" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_youtube != blank %}
            <a href="{{ settings.social_youtube }}" class="footer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'menu_column' %}
          <div class="footer__col" {{ block.shopify_attributes }}>
            <h4 class="footer__col-title">{{ block.settings.title }}</h4>
            {% assign menu = linklists[block.settings.menu] %}
            {% for link in menu.links %}
              <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
            {% endfor %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="footer__bottom">
      <div class="footer__legal">
        <span class="footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados.</span>
        <div class="footer__legal-links">
          <a href="/policies/privacy-policy" class="footer__legal-link">Politica de Privacidad</a>
          <a href="/policies/terms-of-service" class="footer__legal-link">Terminos de Servicio</a>
          <a href="/policies/shipping-policy" class="footer__legal-link">Envios y Devoluciones</a>
        </div>
      </div>
      <div class="footer__payments">
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
        {% endfor %}
        {%- comment -%} Fallback payment icons if none enabled {%- endcomment -%}
        {% if shop.enabled_payment_types.size == 0 %}
          <svg class="footer__payment-icon" width="38" height="24" viewBox="0 0 38 24" fill="none"><rect width="38" height="24" rx="4" fill="#1A1F71"/><text x="8" y="16" fill="white" font-size="10" font-weight="bold">VISA</text></svg>
          <svg class="footer__payment-icon" width="38" height="24" viewBox="0 0 38 24" fill="none"><rect width="38" height="24" rx="4" fill="#252525"/><circle cx="15" cy="12" r="7" fill="#EB001B"/><circle cx="23" cy="12" r="7" fill="#F79E1B"/></svg>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Pie de Pagina",
  "settings": [
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Descripcion",
      "default": "Bienestar natural diseñado para la mujer moderna. Suplementos que tu cuerpo agradece."
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Columna de menu",
      "settings": [
        { "type": "text", "id": "title", "label": "Titulo", "default": "Tienda" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer Saluva"
    }
  ]
}
{% endschema %}

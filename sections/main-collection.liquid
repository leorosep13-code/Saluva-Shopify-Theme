<section class="collection-page" style="padding: 40px 0 70px;">
  <div class="container">
    <div class="section-header section-header--center">
      <h1 class="section-header__title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <p class="section-header__desc">{{ collection.description }}</p>
      {% endif %}
    </div>

    <div class="tienda-grid">
      {% for product in collection.products %}
        <div class="tienda-grid__item" data-type="{{ product.type | handleize }}">
          {% render 'product-card', product: product %}
        </div>
      {% endfor %}
    </div>

    {% if collection.products.size == 0 %}
      <p style="text-align: center; color: var(--color-text-muted); padding: 60px 0;">
        No hay productos en esta colección todavía.
      </p>
    {% endif %}

    {% if paginate.pages > 1 %}
      <div style="text-align: center; margin-top: 40px;">
        {{ paginate | default_pagination }}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Colección Principal",
  "settings": []
}
{% endschema %}

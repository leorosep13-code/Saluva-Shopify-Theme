<section class="trust-badges">
  <div class="container">
    <div class="trust-badges__grid anim-stagger">
      {% for block in section.blocks %}
        <div class="trust-badges__item" {{ block.shopify_attributes }}>
          <span class="trust-badges__icon">{{ block.settings.emoji }}</span>
          <span class="trust-badges__text">{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Badges de Confianza",
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji", "default": "🌱" },
        { "type": "text", "id": "text", "label": "Texto", "default": "100% Natural" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Badges de Confianza",
      "blocks": [
        { "type": "badge", "settings": { "emoji": "🌱", "text": "100% Natural" } },
        { "type": "badge", "settings": { "emoji": "🧪", "text": "Clínicamente Probado" } },
        { "type": "badge", "settings": { "emoji": "🇨🇴", "text": "Hecho en Colombia" } },
        { "type": "badge", "settings": { "emoji": "📦", "text": "Envío Gratis +$80K" } }
      ]
    }
  ]
}
{% endschema %}

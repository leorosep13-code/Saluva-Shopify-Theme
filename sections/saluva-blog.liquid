<section class="blog-section">
  <div class="container">
    <div class="section-header section-header--split anim-slide-left">
      <div>
        <span class="section-header__label">{{ section.settings.label }}</span>
        <h2 class="section-header__title">{{ section.settings.title }}</h2>
      </div>
      {% if section.settings.view_all_url != blank %}
        <a href="{{ section.settings.view_all_url }}" class="btn btn--outline btn--md">
          Ver Todo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {% endif %}
    </div>

    <div class="blog-grid">
      {% assign blog_handle = section.settings.blog | default: 'blog' %}
      {% assign target_blog = blogs[blog_handle] %}
      {% if target_blog.articles.size > 0 %}
        {% for article in target_blog.articles limit: 3 %}
          <article class="blog-card anim-zoom" data-delay="{{ forloop.index0 | times: 120 }}">
            <a href="{{ article.url }}" class="blog-card__media">
              {% if article.image != blank %}
                <img src="{{ article.image | image_url: width: 600 }}"
                     alt="{{ article.image.alt | default: article.title }}"
                     class="blog-card__img"
                     loading="lazy">
              {% else %}
                <div class="blog-card__placeholder">
                  <span>📝</span>
                </div>
              {% endif %}
            </a>
            <div class="blog-card__content">
              <div class="blog-card__meta">
                <span class="blog-card__author">{{ article.author }}</span>
                <span class="blog-card__date">{{ article.published_at | date: '%d %b %Y' }}</span>
              </div>
              <h3 class="blog-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>
            </div>
          </article>
        {% endfor %}
      {% else %}
        {%- comment -%} Placeholder blog cards {%- endcomment -%}
        {% for i in (1..3) %}
          <article class="blog-card anim-zoom" data-delay="{{ forloop.index0 | times: 120 }}">
            <div class="blog-card__media">
              <div class="blog-card__placeholder">
                <span>📝</span>
              </div>
            </div>
            <div class="blog-card__content">
              <div class="blog-card__meta">
                <span class="blog-card__author">Saluva Team</span>
                <span class="blog-card__date">01 Abr 2026</span>
              </div>
              <h3 class="blog-card__title">Titulo del Articulo {{ i }}</h3>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog Destacado",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "NUESTRO BLOG"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Blog Destacado"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog a mostrar"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "URL de ver todo"
    }
  ],
  "presets": [
    {
      "name": "Blog Destacado Saluva"
    }
  ]
}
{% endschema %}

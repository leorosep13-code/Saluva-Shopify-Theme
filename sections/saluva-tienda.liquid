<section id="tienda" class="tienda-section">
  <div class="container">
    <div class="section-header section-header--center anim-flip">
      <span class="section-header__label">{{ section.settings.label }}</span>
      <h2 class="section-header__title">{{ section.settings.title }}</h2>
    </div>

    {% assign collection = collections[section.settings.collection] | default: collections['all'] %}

    <!-- Filters + Sort Bar -->
    <div class="tienda-toolbar">
      <div class="tienda-filters" id="tienda-filters">
        <button class="tienda-filter active" data-filter="all">Todos</button>
        {% for product_type in collection.all_types %}
          {% if product_type != blank %}
            <button class="tienda-filter" data-filter="{{ product_type | handleize }}">
              {{ product_type }}
            </button>
          {% endif %}
        {% endfor %}
      </div>
      <div class="tienda-sort">
        <label for="tienda-sort" class="tienda-sort__label">Ordenar por:</label>
        <select id="tienda-sort" class="tienda-sort__select">
          <option value="best-selling">Mas vendidos</option>
          <option value="price-asc">Precio: Menor a Mayor</option>
          <option value="price-desc">Precio: Mayor a Menor</option>
          <option value="newest">Mas recientes</option>
        </select>
      </div>
    </div>

    <!-- Products count -->
    <p class="tienda-count">{{ collection.products_count }} Productos</p>

    <!-- Products Grid -->
    <div class="tienda-grid" id="tienda-grid">
      {% for product in collection.products limit: section.settings.products_limit %}
        <div class="tienda-grid__item anim-zoom"
             data-type="{{ product.type | handleize }}"
             data-price="{{ product.price }}"
             data-date="{{ product.published_at | date: '%s' }}"
             data-delay="{{ forloop.index0 | times: 80 }}">
          {% render 'product-card', product: product %}
        </div>
      {% endfor %}
    </div>

    {% if collection.products.size > section.settings.products_limit %}
      <div class="tienda-section__more">
        <a href="{{ collection.url }}" class="btn btn--outline btn--md">
          Ver Todos los Productos
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Tienda",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta superior",
      "default": "NUESTRA TIENDA"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Explora Nuestros Productos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleccion a mostrar"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Maximo de productos",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Tienda Saluva"
    }
  ]
}
{% endschema %}

<section id="sobre-nosotros" class="sobre-nosotros aurora-bg">
  <div class="container">
    <div class="sobre-hero">
      <div class="sobre-hero__content">
        {% if section.settings.label != blank %}
          <span class="section-header__label text-primary">{{ section.settings.label }}</span>
        {% endif %}
        <h1 class="sobre-hero__title">{{ section.settings.title }}</h1>
        {% if section.settings.description != blank %}
          <p class="sobre-hero__desc">{{ section.settings.description }}</p>
        {% endif %}
      </div>
      {% if section.settings.image != blank %}
        <div class="sobre-hero__media">
          <img src="{{ section.settings.image | image_url: width: 800 }}"
               alt="{{ section.settings.title }}"
               class="sobre-hero__img"
               loading="lazy">
        </div>
      {% endif %}
    </div>

    <div class="sobre-stack">
      {% for block in section.blocks %}
        {%- assign anchor = block.settings.anchor_id | default: block.id -%}

        {% case block.type %}

        {%- comment -%} ───── Imagen + texto (historia / marcas / apartado genérico) ───── {%- endcomment -%}
        {% when 'historia' or 'marcas' or 'apartado' %}
          {%- assign layout = block.settings.layout | default: 'image-left' -%}
          {%- assign focus = block.settings.image_focus | default: 'top' -%}
          <article id="{{ anchor }}"
                   class="sobre-block sobre-block--{{ layout }}"
                   {{ block.shopify_attributes }}>
            <div class="sobre-block__media sobre-block__media--focus-{{ focus }}">
              {% if block.settings.video_url != blank %}
                {%- assign video_src = block.settings.video_url -%}
                {% if video_src contains 'youtube' or video_src contains 'youtu.be' %}
                  {%- assign yt_id = '' -%}
                  {% if video_src contains 'watch?v=' %}
                    {%- assign yt_id = video_src | split: 'watch?v=' | last | split: '&' | first -%}
                  {% elsif video_src contains 'youtu.be/' %}
                    {%- assign yt_id = video_src | split: 'youtu.be/' | last | split: '?' | first -%}
                  {% elsif video_src contains 'embed/' %}
                    {%- assign yt_id = video_src | split: 'embed/' | last | split: '?' | first -%}
                  {% endif %}
                  <div class="sobre-block__video">
                    <iframe src="https://www.youtube.com/embed/{{ yt_id }}"
                            title="{{ block.settings.title }}"
                            frameborder="0"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen
                            loading="lazy"></iframe>
                  </div>
                {% elsif video_src contains 'vimeo' %}
                  {%- assign vimeo_id = video_src | split: 'vimeo.com/' | last | split: '?' | first -%}
                  <div class="sobre-block__video">
                    <iframe src="https://player.vimeo.com/video/{{ vimeo_id }}"
                            title="{{ block.settings.title }}"
                            frameborder="0"
                            allow="autoplay; fullscreen; picture-in-picture"
                            allowfullscreen
                            loading="lazy"></iframe>
                  </div>
                {% else %}
                  <div class="sobre-block__video">
                    <video src="{{ video_src }}" controls preload="metadata" playsinline></video>
                  </div>
                {% endif %}
              {% elsif block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 900 }}"
                     alt="{{ block.settings.title }}"
                     class="sobre-block__img"
                     loading="lazy">
              {% else %}
                <div class="sobre-block__placeholder">
                  <span>{{ block.settings.emoji | default: '✨' }}</span>
                </div>
              {% endif %}
            </div>
            <div class="sobre-block__content">
              {% if block.settings.label != blank %}
                <span class="sobre-block__label">{{ block.settings.label }}</span>
              {% endif %}
              <h2 class="sobre-block__title">{{ block.settings.title }}</h2>
              <div class="sobre-block__body">{{ block.settings.body }}</div>
              {% if block.settings.cta_text != blank and block.settings.cta_url != blank %}
                <a href="{{ block.settings.cta_url }}" class="btn btn--primary btn--md">{{ block.settings.cta_text }}</a>
              {% endif %}
            </div>
          </article>

        {%- comment -%} ───── Valores (galería de 5 imágenes con texto) ───── {%- endcomment -%}
        {% when 'valores' %}
          <article id="{{ anchor }}"
                   class="sobre-block sobre-block--valores"
                   {{ block.shopify_attributes }}>
            <header class="sobre-block__head">
              {% if block.settings.label != blank %}
                <span class="sobre-block__label">{{ block.settings.label }}</span>
              {% endif %}
              <h2 class="sobre-block__title">{{ block.settings.title }}</h2>
              {% if block.settings.body != blank %}
                <div class="sobre-block__body sobre-block__body--centered">{{ block.settings.body }}</div>
              {% endif %}
            </header>
            <div class="sobre-gallery">
              {% for i in (1..5) %}
                {%- assign img_key = 'image_' | append: i -%}
                {%- assign cap_key = 'caption_' | append: i -%}
                {%- assign txt_key = 'text_' | append: i -%}
                {%- assign img = block.settings[img_key] -%}
                {%- assign cap = block.settings[cap_key] -%}
                {%- assign txt = block.settings[txt_key] -%}
                <figure class="sobre-gallery__item sobre-gallery__item--{{ i }}">
                  {% if img != blank %}
                    <img src="{{ img | image_url: width: 800 }}"
                         alt="{{ cap | default: 'Valor misoji' }}"
                         class="sobre-gallery__img"
                         loading="lazy">
                  {% else %}
                    <div class="sobre-gallery__placeholder">{{ forloop.index }}</div>
                  {% endif %}
                  {% if cap != blank or txt != blank %}
                    <figcaption class="sobre-gallery__cap">
                      {% if cap != blank %}<strong class="sobre-gallery__cap-title">{{ cap }}</strong>{% endif %}
                      {% if txt != blank %}<span class="sobre-gallery__cap-text">{{ txt }}</span>{% endif %}
                    </figcaption>
                  {% endif %}
                </figure>
              {% endfor %}
            </div>
          </article>

        {%- comment -%} ───── Servicio al cliente (4 tarjetas con hipervínculo) ───── {%- endcomment -%}
        {% when 'servicio' %}
          <article id="{{ anchor }}"
                   class="sobre-block sobre-block--servicio"
                   {{ block.shopify_attributes }}>
            <header class="sobre-block__head">
              {% if block.settings.label != blank %}
                <span class="sobre-block__label">{{ block.settings.label }}</span>
              {% endif %}
              <h2 class="sobre-block__title">{{ block.settings.title }}</h2>
              {% if block.settings.body != blank %}
                <div class="sobre-block__body sobre-block__body--centered">{{ block.settings.body }}</div>
              {% endif %}
            </header>
            <div class="sobre-services">
              {% for i in (1..4) %}
                {%- assign img_key   = 'card_image_' | append: i -%}
                {%- assign title_key = 'card_title_' | append: i -%}
                {%- assign desc_key  = 'card_desc_'  | append: i -%}
                {%- assign url_key   = 'card_url_'   | append: i -%}
                {%- assign focus_key = 'card_focus_' | append: i -%}
                {%- assign card_img   = block.settings[img_key] -%}
                {%- assign card_title = block.settings[title_key] -%}
                {%- assign card_desc  = block.settings[desc_key] -%}
                {%- assign card_url   = block.settings[url_key] -%}
                {%- assign card_focus = block.settings[focus_key] | default: 'center' -%}
                {%- assign tag = 'div' -%}
                {% if card_url != blank %}{%- assign tag = 'a' -%}{% endif %}
                <{{ tag }}
                  {% if card_url != blank %}href="{{ card_url }}"{% endif %}
                  class="sobre-service{% if card_url != blank %} sobre-service--link{% endif %}">
                  <div class="sobre-service__media sobre-service__media--focus-{{ card_focus }}">
                    {% if card_img != blank %}
                      <img src="{{ card_img | image_url: width: 700 }}"
                           alt="{{ card_title | default: 'Servicio misoji' }}"
                           class="sobre-service__img"
                           loading="lazy">
                    {% else %}
                      <div class="sobre-service__placeholder">{{ forloop.index }}</div>
                    {% endif %}
                  </div>
                  <div class="sobre-service__body">
                    <strong class="sobre-service__title">{{ card_title | default: 'Opción de servicio' }}</strong>
                    {% if card_desc != blank %}
                      <span class="sobre-service__desc">{{ card_desc }}</span>
                    {% endif %}
                  </div>
                </{{ tag }}>
              {% endfor %}
            </div>
            {% if block.settings.cta_text != blank and block.settings.cta_url != blank %}
              <div class="sobre-block__cta-row">
                <a href="{{ block.settings.cta_url }}" class="btn btn--primary btn--md">{{ block.settings.cta_text }}</a>
              </div>
            {% endif %}
          </article>

        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>


{%- comment -%}
  Sobre Nosotros — reescrito con los patrones de la landing.
  Hero: texto + imagen cuadrada (estilo featured-product).
  Historia: imagen cuadrada + texto.
  Valores: 4 tarjetas cuadradas (estilo why-us).
  Servicio: 4 tarjetas cuadradas con link (estilo why-us).
{%- endcomment -%}

<section id="sobre-nosotros" class="about-page aurora-bg">
  <div class="container">

    {%- comment -%} ── Hero: texto + imagen cuadrada ── {%- endcomment -%}
    <div class="about-hero">
      <div class="about-hero__content">
        {% if section.settings.label != blank %}
          <span class="about-hero__label">{{ section.settings.label }}</span>
        {% endif %}
        <h1 class="about-hero__title">{{ section.settings.title }}</h1>
        {% if section.settings.description != blank %}
          <p class="about-hero__desc">{{ section.settings.description }}</p>
        {% endif %}
        {% if section.settings.cta_text != blank and section.settings.cta_url != blank %}
          <a href="{{ section.settings.cta_url }}" class="btn btn--primary btn--md about-hero__cta">{{ section.settings.cta_text }}</a>
        {% endif %}
      </div>
      <div class="about-hero__media">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | image_url: width: 900 }}"
               alt="{{ section.settings.title }}"
               class="about-hero__img"
               loading="lazy">
        {% else %}
          <div class="about-hero__placeholder">✨</div>
        {% endif %}
      </div>
    </div>

    {%- comment -%} ── Bloques ── {%- endcomment -%}
    {% for block in section.blocks %}
      {%- assign anchor = block.settings.anchor_id | default: block.id -%}

      {% case block.type %}

      {%- comment -%} ── HISTORIA: imagen cuadrada + texto (configurable izquierda/derecha) ── {%- endcomment -%}
      {% when 'historia' %}
        {%- assign layout = block.settings.layout | default: 'image-left' -%}
        <article id="{{ anchor }}"
                 class="about-feature about-feature--{{ layout }}"
                 {{ block.shopify_attributes }}>
          <div class="about-feature__media">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 900 }}"
                   alt="{{ block.settings.title }}"
                   class="about-feature__img"
                   loading="lazy">
            {% else %}
              <div class="about-feature__placeholder">{{ block.settings.emoji | default: '🌿' }}</div>
            {% endif %}
          </div>
          <div class="about-feature__content">
            {% if block.settings.label != blank %}
              <span class="about-feature__label">{{ block.settings.label }}</span>
            {% endif %}
            <h2 class="about-feature__title">{{ block.settings.title }}</h2>
            <div class="about-feature__body">{{ block.settings.body }}</div>
            {% if block.settings.cta_text != blank and block.settings.cta_url != blank %}
              <a href="{{ block.settings.cta_url }}" class="btn btn--primary btn--md">{{ block.settings.cta_text }}</a>
            {% endif %}
          </div>
        </article>

      {%- comment -%} ── VALORES: 4 tarjetas cuadradas estilo why-us ── {%- endcomment -%}
      {% when 'valores' %}
        <article id="{{ anchor }}"
                 class="about-section"
                 {{ block.shopify_attributes }}>
          <header class="about-section__head">
            {% if block.settings.label != blank %}
              <span class="about-section__label">{{ block.settings.label }}</span>
            {% endif %}
            <h2 class="about-section__title">{{ block.settings.title }}</h2>
            {% if block.settings.body != blank %}
              <div class="about-section__desc">{{ block.settings.body }}</div>
            {% endif %}
          </header>
          <div class="about-grid">
            {% for i in (1..4) %}
              {%- assign img_key   = 'image_'   | append: i -%}
              {%- assign title_key = 'caption_' | append: i -%}
              {%- assign desc_key  = 'text_'    | append: i -%}
              {%- assign card_img   = block.settings[img_key] -%}
              {%- assign card_title = block.settings[title_key] -%}
              {%- assign card_desc  = block.settings[desc_key] -%}
              <div class="about-card">
                <div class="about-card__media">
                  {% if card_img != blank %}
                    <img src="{{ card_img | image_url: width: 600 }}"
                         alt="{{ card_title | default: 'Valor misoji' }}"
                         class="about-card__img"
                         loading="lazy">
                  {% else %}
                    <div class="about-card__placeholder">{{ forloop.index }}</div>
                  {% endif %}
                </div>
                <div class="about-card__body">
                  <h3 class="about-card__title">{{ card_title | default: 'Valor' }}</h3>
                  {% if card_desc != blank %}
                    <p class="about-card__desc">{{ card_desc }}</p>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </article>

      {%- comment -%} ── SERVICIO: 4 tarjetas con link ── {%- endcomment -%}
      {% when 'servicio' %}
        <article id="{{ anchor }}"
                 class="about-section"
                 {{ block.shopify_attributes }}>
          <header class="about-section__head">
            {% if block.settings.label != blank %}
              <span class="about-section__label">{{ block.settings.label }}</span>
            {% endif %}
            <h2 class="about-section__title">{{ block.settings.title }}</h2>
            {% if block.settings.body != blank %}
              <div class="about-section__desc">{{ block.settings.body }}</div>
            {% endif %}
          </header>
          <div class="about-grid">
            {% for i in (1..4) %}
              {%- assign img_key   = 'card_image_' | append: i -%}
              {%- assign title_key = 'card_title_' | append: i -%}
              {%- assign desc_key  = 'card_desc_'  | append: i -%}
              {%- assign url_key   = 'card_url_'   | append: i -%}
              {%- assign card_img   = block.settings[img_key] -%}
              {%- assign card_title = block.settings[title_key] -%}
              {%- assign card_desc  = block.settings[desc_key] -%}
              {%- assign card_url   = block.settings[url_key] -%}
              {%- assign tag = 'div' -%}
              {% if card_url != blank %}{%- assign tag = 'a' -%}{% endif %}
              <{{ tag }}
                {% if card_url != blank %}href="{{ card_url }}"{% endif %}
                class="about-card{% if card_url != blank %} about-card--link{% endif %}">
                <div class="about-card__media">
                  {% if card_img != blank %}
                    <img src="{{ card_img | image_url: width: 600 }}"
                         alt="{{ card_title | default: 'Servicio misoji' }}"
                         class="about-card__img"
                         loading="lazy">
                  {% else %}
                    <div class="about-card__placeholder">{{ forloop.index }}</div>
                  {% endif %}
                </div>
                <div class="about-card__body">
                  <h3 class="about-card__title">{{ card_title | default: 'Opción de servicio' }}</h3>
                  {% if card_desc != blank %}
                    <p class="about-card__desc">{{ card_desc }}</p>
                  {% endif %}
                </div>
              </{{ tag }}>
            {% endfor %}
          </div>
          {% if block.settings.cta_text != blank and block.settings.cta_url != blank %}
            <div class="about-section__cta">
              <a href="{{ block.settings.cta_url }}" class="btn btn--primary btn--md">{{ block.settings.cta_text }}</a>
            </div>
          {% endif %}
        </article>

      {% endcase %}
    {% endfor %}

  </div>
</section>

{% schema %}
{
  "name": "Sobre Nosotros",
  "settings": [
    { "type": "text", "id": "label", "label": "Etiqueta superior", "default": "NUESTRA ESENCIA" },
    { "type": "text", "id": "title", "label": "Título", "default": "Sobre Nosotros" },
    { "type": "textarea", "id": "description", "label": "Descripción", "default": "Detrás de misoji hay un equipo apasionado por la belleza y la tecnología. Conoce nuestra historia, valores y compromiso." },
    { "type": "image_picker", "id": "image", "label": "Imagen hero (cuadrada recomendada)" },
    { "type": "text", "id": "cta_text", "label": "Texto CTA hero (opcional)" },
    { "type": "url", "id": "cta_url", "label": "URL CTA hero (opcional)" }
  ],
  "blocks": [
    {
      "type": "historia",
      "name": "Nuestra historia",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "anchor_id", "label": "ID ancla (sin #)", "default": "nuestra-historia" },
        { "type": "text", "id": "label", "label": "Etiqueta pequeña", "default": "CAPÍTULO 01" },
        { "type": "text", "id": "title", "label": "Título", "default": "Nuestra historia" },
        { "type": "richtext", "id": "body", "label": "Contenido", "default": "<p>Cuenta aquí la historia de tu marca: cómo nació, qué te inspiró y a dónde quieren llegar.</p>" },
        { "type": "image_picker", "id": "image", "label": "Imagen (cuadrada recomendada)" },
        { "type": "text", "id": "emoji", "label": "Emoji fallback", "default": "🌿" },
        {
          "type": "select",
          "id": "layout",
          "label": "Disposición",
          "options": [
            { "value": "image-left", "label": "Imagen a la izquierda" },
            { "value": "image-right", "label": "Imagen a la derecha" }
          ],
          "default": "image-left"
        },
        { "type": "text", "id": "cta_text", "label": "Texto CTA (opcional)" },
        { "type": "url", "id": "cta_url", "label": "URL CTA (opcional)" }
      ]
    },
    {
      "type": "valores",
      "name": "Nuestros valores (4 tarjetas)",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "anchor_id", "label": "ID ancla (sin #)", "default": "nuestros-valores" },
        { "type": "text", "id": "label", "label": "Etiqueta pequeña", "default": "CAPÍTULO 02" },
        { "type": "text", "id": "title", "label": "Título", "default": "Nuestros valores" },
        { "type": "richtext", "id": "body", "label": "Introducción", "default": "<p>Lo que nos guía cada día y nos hace ser diferentes.</p>" },
        { "type": "header", "content": "Valor 1" },
        { "type": "image_picker", "id": "image_1", "label": "Imagen" },
        { "type": "text", "id": "caption_1", "label": "Título", "default": "Calidad" },
        { "type": "text", "id": "text_1", "label": "Descripción corta", "default": "Cada dispositivo pasa rigurosos controles." },
        { "type": "header", "content": "Valor 2" },
        { "type": "image_picker", "id": "image_2", "label": "Imagen" },
        { "type": "text", "id": "caption_2", "label": "Título", "default": "Cercanía" },
        { "type": "text", "id": "text_2", "label": "Descripción corta", "default": "Acompañamos en cada paso." },
        { "type": "header", "content": "Valor 3" },
        { "type": "image_picker", "id": "image_3", "label": "Imagen" },
        { "type": "text", "id": "caption_3", "label": "Título", "default": "Transparencia" },
        { "type": "text", "id": "text_3", "label": "Descripción corta", "default": "Decimos las cosas como son." },
        { "type": "header", "content": "Valor 4" },
        { "type": "image_picker", "id": "image_4", "label": "Imagen" },
        { "type": "text", "id": "caption_4", "label": "Título", "default": "Innovación" },
        { "type": "text", "id": "text_4", "label": "Descripción corta", "default": "Tecnología siempre actualizada." }
      ]
    },
    {
      "type": "servicio",
      "name": "Servicio al cliente (4 tarjetas)",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "anchor_id", "label": "ID ancla (sin #)", "default": "servicio-al-cliente" },
        { "type": "text", "id": "label", "label": "Etiqueta pequeña", "default": "CAPÍTULO 03" },
        { "type": "text", "id": "title", "label": "Título", "default": "Servicio al cliente" },
        { "type": "richtext", "id": "body", "label": "Introducción", "default": "<p>Te acompañamos antes, durante y después de tu compra. Garantía, soporte y asesoría personalizada para tu rutina de belleza.</p>" },
        { "type": "text", "id": "cta_text", "label": "Texto CTA secundario (opcional)" },
        { "type": "url", "id": "cta_url", "label": "URL CTA secundario (opcional)" },
        { "type": "header", "content": "Tarjeta 1" },
        { "type": "image_picker", "id": "card_image_1", "label": "Imagen" },
        { "type": "text", "id": "card_title_1", "label": "Título", "default": "Garantía" },
        { "type": "text", "id": "card_desc_1", "label": "Descripción corta", "default": "Respaldo en cada compra." },
        { "type": "url", "id": "card_url_1", "label": "URL al hacer clic" },
        { "type": "header", "content": "Tarjeta 2" },
        { "type": "image_picker", "id": "card_image_2", "label": "Imagen" },
        { "type": "text", "id": "card_title_2", "label": "Título", "default": "Envíos" },
        { "type": "text", "id": "card_desc_2", "label": "Descripción corta", "default": "Llevamos tu pedido a todo el país." },
        { "type": "url", "id": "card_url_2", "label": "URL al hacer clic" },
        { "type": "header", "content": "Tarjeta 3" },
        { "type": "image_picker", "id": "card_image_3", "label": "Imagen" },
        { "type": "text", "id": "card_title_3", "label": "Título", "default": "Asesoría personalizada" },
        { "type": "text", "id": "card_desc_3", "label": "Descripción corta", "default": "Te ayudamos a elegir." },
        { "type": "url", "id": "card_url_3", "label": "URL al hacer clic" },
        { "type": "header", "content": "Tarjeta 4" },
        { "type": "image_picker", "id": "card_image_4", "label": "Imagen" },
        { "type": "text", "id": "card_title_4", "label": "Título", "default": "Contacto" },
        { "type": "text", "id": "card_desc_4", "label": "Descripción corta", "default": "Escríbenos cuando quieras." },
        { "type": "url", "id": "card_url_4", "label": "URL al hacer clic" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sobre Nosotros",
      "blocks": [
        { "type": "historia" },
        { "type": "valores" },
        { "type": "servicio" }
      ]
    }
  ]
}
{% endschema %}

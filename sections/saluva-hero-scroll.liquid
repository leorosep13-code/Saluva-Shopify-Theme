{% comment %}
  SALUVA Hero Scroll — GSAP ScrollTrigger Animation
  Frasco que se abre con explosión de cápsulas al hacer scroll.
{% endcomment %}

<section class="hero-scroll" id="hero-scroll" style="background-color: {{ section.settings.bg_color }}">
  <div class="hero-scroll__container">
    {%- comment -%} Referencia de alineación — oculta {%- endcomment -%}
    <img
      class="hero-scroll__img hero-scroll__img--cerrado"
      src="{{ 'frasco_cerrado.png' | asset_url }}"
      alt=""
      aria-hidden="true"
      draggable="false"
    >

    {%- comment -%} Base estática — frasco abierto {%- endcomment -%}
    <img
      class="hero-scroll__img hero-scroll__img--base"
      src="{{ 'frasco_abierto.png' | asset_url }}"
      alt="Frasco Saluva abierto"
      draggable="false"
    >

    {%- comment -%} Tapa animada {%- endcomment -%}
    <img
      class="hero-scroll__img hero-scroll__img--tapa"
      id="hero-tapa"
      src="{{ 'tapa.png' | asset_url }}"
      alt="Tapa del frasco"
      draggable="false"
    >

    {%- comment -%} 8 cápsulas generadas por JS {%- endcomment -%}
    <div class="hero-scroll__capsulas" id="hero-capsulas">
      {% for i in (1..8) %}
        <img
          class="hero-scroll__capsula"
          src="{{ 'capsulas.png' | asset_url }}"
          alt=""
          aria-hidden="true"
          draggable="false"
        >
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .hero-scroll {
    position: relative;
    height: 100vh;
    background-color: #F0E6FA;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-scroll__container {
    position: relative;
    width: clamp(220px, 40vw, 420px);
    aspect-ratio: 3 / 4;
  }

  .hero-scroll__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
  }

  /* Referencia oculta */
  .hero-scroll__img--cerrado {
    visibility: hidden;
  }

  /* Tapa: will-change para rendimiento GPU */
  .hero-scroll__img--tapa {
    will-change: transform;
    transform-origin: center bottom;
  }

  /* Cápsulas */
  .hero-scroll__capsulas {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-scroll__capsula {
    position: absolute;
    width: clamp(32px, 8vw, 60px);
    height: auto;
    left: 50%;
    top: 55%;
    transform: translate(-50%, -50%) scale(0);
    will-change: transform, opacity;
    opacity: 0;
  }

  /* Responsive */
  @media (max-width: 749px) {
    .hero-scroll__container {
      width: clamp(180px, 65vw, 300px);
    }
    .hero-scroll__capsula {
      width: clamp(24px, 10vw, 44px);
    }
  }
</style>

<script>
  (function () {
    /* ── Carga GSAP + ScrollTrigger si no están disponibles ── */
    function loadScript(src) {
      return new Promise(function (resolve, reject) {
        if (document.querySelector('script[src="' + src + '"]')) { resolve(); return; }
        var s = document.createElement('script');
        s.src = src;
        s.onload = resolve;
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    function ensureGSAP() {
      if (window.gsap && window.ScrollTrigger) return Promise.resolve();
      return loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js')
        .then(function () {
          return loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js');
        });
    }

    /* ── Posiciones de explosión para las 8 cápsulas ── */
    function getCapsuleTargets() {
      var base = [
        { x: -120, y: -180, rot: -35, s: 1.1 },
        { x:  130, y: -160, rot:  25, s: 0.9 },
        { x: -160, y:  -60, rot:  40, s: 1.0 },
        { x:  170, y:  -40, rot: -20, s: 0.85 },
        { x:  -90, y: -260, rot:  15, s: 0.75 },
        { x:  100, y: -240, rot: -30, s: 0.95 },
        { x: -180, y: -140, rot:  50, s: 0.8 },
        { x:  150, y: -120, rot: -45, s: 1.05 }
      ];
      /* Escalar según viewport */
      var vw = window.innerWidth;
      var scale = vw < 750 ? 0.55 : vw < 1024 ? 0.75 : 1;
      return base.map(function (t) {
        return { x: t.x * scale, y: t.y * scale, rotation: t.rot, scale: t.s };
      });
    }

    /* ── Inicializar animación ── */
    function initHeroScroll() {
      var section = document.getElementById('hero-scroll');
      var tapa = document.getElementById('hero-tapa');
      var capsulas = document.querySelectorAll('#hero-capsulas .hero-scroll__capsula');

      if (!section || !tapa || capsulas.length === 0) return;

      gsap.registerPlugin(ScrollTrigger);

      var targets = getCapsuleTargets();

      var tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: '+=150%',
          pin: true,
          scrub: 1,
          anticipatePin: 1
        }
      });

      /* Fase 1 (0 → 0.4): la tapa sube y rota */
      tl.to(tapa, {
        y: '-60%',
        rotation: 20,
        duration: 0.4,
        ease: 'power2.out'
      });

      /* Fase 2 (0.25 → 1): cápsulas explotan (se solapa con la tapa) */
      capsulas.forEach(function (cap, i) {
        var t = targets[i];
        tl.fromTo(cap, {
          x: 0,
          y: 0,
          scale: 0,
          rotation: 0,
          opacity: 0
        }, {
          x: t.x,
          y: t.y,
          scale: t.scale,
          rotation: t.rotation,
          opacity: 1,
          duration: 0.6,
          ease: 'back.out(1.4)'
        }, 0.25 + i * 0.04);
      });

      /* Recalcular en resize */
      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
          ScrollTrigger.refresh();
        }, 250);
      });
    }

    /* ── Boot ── */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        ensureGSAP().then(initHeroScroll);
      });
    } else {
      ensureGSAP().then(initHeroScroll);
    }
  })();
</script>

{% schema %}
{
  "name": "Hero Scroll GSAP",
  "tag": "section",
  "class": "section-hero-scroll",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#F0E6FA"
    }
  ],
  "presets": [
    {
      "name": "Hero Scroll GSAP"
    }
  ]
}
{% endschema %}

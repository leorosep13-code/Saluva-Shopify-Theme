{% comment %}
  SALUVA Hero Scroll — Premium GSAP ScrollTrigger Animation
  Assets: frasco_abierto.png (base) + capsulas.png (racimo único)
  CSS → saluva-sections.css | JS → saluva-scripts.js
{% endcomment %}

<section
  class="saluva-hero"
  id="saluva-hero"
  data-section-id="{{ section.id }}"
>
  {%- comment -%} Capa 1 — Frasco base {%- endcomment -%}
  <img
    class="saluva-hero__frasco"
    id="saluva-hero-frasco"
    src="{{ 'frasco_abierto.png' | asset_url }}"
    alt="Frasco Saluva"
    loading="eager"
    draggable="false"
  >

  {%- comment -%} Capa 2 — Racimo de cápsulas {%- endcomment -%}
  <img
    class="saluva-hero__capsulas"
    id="saluva-hero-capsulas"
    src="{{ 'capsulas.png' | asset_url }}"
    alt="Cápsulas Saluva"
    loading="eager"
    draggable="false"
  >
</section>

{% schema %}
{
  "name": "Hero Scroll Premium",
  "tag": "section",
  "class": "section-hero-saluva",
  "settings": [],
  "presets": [
    {
      "name": "Hero Scroll Premium"
    }
  ]
}
{% endschema %}

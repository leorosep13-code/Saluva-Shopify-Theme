<div class="promo-bar" id="promo-bar">
  <div class="promo-bar__inner">
    <span class="promo-bar__text">
      {{ section.settings.icon }} {{ section.settings.text }}
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Barra Promocional",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Texto promocional",
      "default": "VENTA ESPECIAL — HASTA 30% OFF"
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Emoji/Ícono",
      "default": "✨"
    }
  ]
}
{% endschema %}

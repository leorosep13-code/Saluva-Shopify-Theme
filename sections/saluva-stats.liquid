{%- comment -%}
  MISOJI — Números clínicos
  Banda de datos/estadísticas para aportar autoridad (ej: "97% reducción de vello").
  Animación count-up al entrar en viewport → initStats() en saluva-scripts.js
{%- endcomment -%}

{%- comment -%} Solo metaobjetos del producto (custom.indicadores). Si el producto no tiene, la sección no aparece. {%- endcomment -%}
{%- assign mo_stats = product.metafields.custom.indicadores.value | default: product.metafields.saluva.indicadores.value -%}

{%- if mo_stats != blank and mo_stats.size > 0 -%}
<section class="saluva-stats {% if section.settings.bg_aurora %}aurora-bg{% endif %}" id="saluva-stats-{{ section.id }}">
  <div class="container">
    {%- if section.settings.title != blank or section.settings.label != blank -%}
      <div class="section-header section-header--center anim-flip">
        {%- if section.settings.label != blank -%}
          <span class="section-header__label">{{ section.settings.label }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="section-header__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="section-header__desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="saluva-stats__grid saluva-stats__grid--mo anim-stagger">
        {%- for item in mo_stats -%}
          {%- assign s_img = item.imagen.value -%}
          {%- assign s_val = item.valor.value | strip -%}
          {%- assign s_desc = item.descripcion.value -%}
          <div class="saluva-stats__item saluva-stats__item--mo">
            {%- if s_img != blank -%}
              <div class="saluva-stats__media">
                <img src="{{ s_img | image_url: width: 320 }}" alt="{{ s_desc | escape }}" loading="lazy" width="160" height="160">
              </div>
            {%- endif -%}
            <div class="saluva-stats__value saluva-stats__value--xl">
              <span class="saluva-stats__number" data-stat-raw="{{ s_val | escape }}">{{ s_val }}</span>
            </div>
            {%- if s_desc != blank -%}
              <p class="saluva-stats__label">{{ s_desc }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

    {%- if section.settings.footnote != blank -%}
      <p class="saluva-stats__footnote">{{ section.settings.footnote }}</p>
    {%- endif -%}
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Números clínicos",
  "settings": [
    { "type": "paragraph", "content": "Los indicadores se toman del metafield del producto «custom.indicadores» (lista de metaobjetos «indicador» con campos imagen, valor y descripcion). El valor (ej. «97%») se anima con conteo ascendente. Si el producto no tiene, se usan los bloques de abajo como respaldo." },
    { "type": "text", "id": "label", "label": "Etiqueta superior", "default": "RESPALDADO POR DATOS" },
    { "type": "text", "id": "title", "label": "Título", "default": "Resultados que puedes medir" },
    { "type": "textarea", "id": "description", "label": "Descripción (opcional)" },
    { "type": "text", "id": "footnote", "label": "Nota al pie (opcional)", "default": "*Resultados según uso constante. Pueden variar según cada persona." },
    { "type": "checkbox", "id": "bg_aurora", "label": "Fondo Aurora", "default": true }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "stat",
      "name": "Dato",
      "settings": [
        { "type": "text", "id": "number", "label": "Número", "default": "97", "info": "Solo el valor numérico. Usa punto para decimales (ej: 97.3)" },
        { "type": "range", "id": "decimals", "label": "Decimales", "min": 0, "max": 2, "step": 1, "default": 0 },
        { "type": "text", "id": "suffix", "label": "Sufijo", "default": "%" },
        { "type": "text", "id": "label", "label": "Texto principal", "default": "Reducción de vello" },
        { "type": "text", "id": "sublabel", "label": "Texto secundario (opcional)", "default": "en solo 2 semanas" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Números clínicos",
      "blocks": [
        { "type": "stat", "settings": { "number": "97", "suffix": "%", "label": "Reducción de vello", "sublabel": "en solo 2 semanas" } },
        { "type": "stat", "settings": { "number": "3", "suffix": "", "label": "Modos personalizados", "sublabel": "rostro · cuerpo · bikini" } },
        { "type": "stat", "settings": { "number": "0", "suffix": "", "label": "Dolor", "sublabel": "tecnología de enfriamiento" } },
        { "type": "stat", "settings": { "number": "30", "suffix": " días", "label": "Garantía", "sublabel": "devolución sin complicaciones" } }
      ]
    }
  ]
}
{% endschema %}

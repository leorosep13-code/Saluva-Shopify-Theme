{% comment %} templates/page.liquid {% endcomment %}
<section class="page-content" style="padding: 40px 0 70px;">
  <div class="container" style="max-width: 800px;">
    <h1 style="font-size: 36px; font-weight: 800; margin-bottom: 24px;">{{ page.title }}</h1>
    <div style="font-size: 16px; color: var(--color-text-muted); line-height: 1.8;">
      {{ page.content }}
    </div>
  </div>
</section>

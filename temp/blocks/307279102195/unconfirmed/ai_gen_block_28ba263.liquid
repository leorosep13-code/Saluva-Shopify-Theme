{% doc %}
  @prompt
    un banner deslozable de promociones, que me deje agregar una imagen al fondo de cada promocion
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-slider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px 0;
  }

  .ai-promo-slider__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-promo-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-promo-slider__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
  }

  .ai-promo-slider__slide-{{ ai_gen_id }} {
    min-width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: {{ block.settings.slide_padding }}px;
    background-color: {{ block.settings.slide_background_color }};
    position: relative;
    min-height: 300px;
  }

  .ai-promo-slider__slide-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .ai-promo-slider__slide-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-promo-slider__slide-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
  }

  .ai-promo-slider__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-promo-slider__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 20px;
    max-width: 600px;
  }

  .ai-promo-slider__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 30px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-promo-slider__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-promo-slider__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 20px;
  }

  .ai-promo-slider__arrow-{{ ai_gen_id }} {
    background-color: {{ block.settings.arrow_color }};
    color: {{ block.settings.arrow_icon_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-promo-slider__arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_color }};
  }

  .ai-promo-slider__arrow-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-promo-slider__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-promo-slider__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
    padding: 0;
  }

  .ai-promo-slider__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-promo-slider__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-promo-slider__description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<promo-slider-{{ ai_gen_id }} class="ai-promo-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-promo-slider__container-{{ ai_gen_id }}">
    <div class="ai-promo-slider__wrapper-{{ ai_gen_id }}">
      <div class="ai-promo-slider__track-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign title_key = 'promo_' | append: i | append: '_title'
            assign description_key = 'promo_' | append: i | append: '_description'
            assign button_text_key = 'promo_' | append: i | append: '_button_text'
            assign button_link_key = 'promo_' | append: i | append: '_button_link'
            assign enabled_key = 'promo_' | append: i | append: '_enabled'
            assign image_key = 'promo_' | append: i | append: '_image'

            assign promo_title = block.settings[title_key]
            assign promo_description = block.settings[description_key]
            assign promo_button_text = block.settings[button_text_key]
            assign promo_button_link = block.settings[button_link_key]
            assign promo_enabled = block.settings[enabled_key]
            assign promo_image = block.settings[image_key]
          %}

          {% if promo_enabled %}
            <div class="ai-promo-slider__slide-{{ ai_gen_id }}" data-slide="{{ forloop.index0 }}">
              {% if promo_image %}
                <img
                  src="{{ promo_image | image_url: width: 2000 }}"
                  alt="{{ promo_image.alt | escape }}"
                  loading="lazy"
                  width="{{ promo_image.width }}"
                  height="{{ promo_image.height }}"
                  class="ai-promo-slider__slide-bg-{{ ai_gen_id }}"
                >
                <div class="ai-promo-slider__slide-overlay-{{ ai_gen_id }}"></div>
              {% endif %}

              <div class="ai-promo-slider__slide-content-{{ ai_gen_id }}">
                {% if promo_title != blank %}
                  <h2 class="ai-promo-slider__title-{{ ai_gen_id }}">{{ promo_title }}</h2>
                {% endif %}

                {% if promo_description != blank %}
                  <div class="ai-promo-slider__description-{{ ai_gen_id }}">{{ promo_description }}</div>
                {% endif %}

                {% if promo_button_text != blank and promo_button_link != blank %}
                  <a href="{{ promo_button_link }}" class="ai-promo-slider__button-{{ ai_gen_id }}">
                    {{ promo_button_text }}
                  </a>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if block.settings.show_controls %}
      <div class="ai-promo-slider__controls-{{ ai_gen_id }}">
        <button class="ai-promo-slider__arrow-{{ ai_gen_id }} ai-promo-slider__prev-{{ ai_gen_id }}" aria-label="Anterior">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <div class="ai-promo-slider__dots-{{ ai_gen_id }}"></div>

        <button class="ai-promo-slider__arrow-{{ ai_gen_id }} ai-promo-slider__next-{{ ai_gen_id }}" aria-label="Siguiente">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</promo-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class PromoSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-promo-slider__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-promo-slider__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-promo-slider__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-promo-slider__next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-promo-slider__dots-{{ ai_gen_id }}');

        if (this.slides.length === 0) return;

        this.createDots();
        this.setupEventListeners();
        this.updateSlider();

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-promo-slider__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Ir a promoción ' + (index + 1));
          if (index === 0) dot.classList.add('active');
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prevSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          {% if block.settings.autoplay %}
            this.startAutoplay();
          {% endif %}
        });
      }

      updateSlider() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = 'translateX(' + offset + '%)';

        const dots = this.querySelectorAll('.ai-promo-slider__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
        this.resetAutoplay();
      }

      nextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.updateSlider();
        this.resetAutoplay();
      }

      prevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.updateSlider();
        this.resetAutoplay();
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('promo-slider-{{ ai_gen_id }}', PromoSlider{{ ai_gen_id }});
  })();
</script>


{% doc %}
  @prompt
    pop app al entrar a la pagina , que les de un bono de descuento , diseño acorde a los colores actuales
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-welcome-popup-{{ ai_gen_id }} {
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-welcome-popup-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-welcome-popup-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    cursor: pointer;
  }

  .ai-welcome-popup-container-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    width: 90%;
    max-width: {{ block.settings.popup_max_width }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .ai-welcome-popup-{{ ai_gen_id }}.active .ai-welcome-popup-container-{{ ai_gen_id }} {
    transform: translate(-50%, -50%) scale(1);
  }

  .ai-welcome-popup-content-{{ ai_gen_id }} {
    padding: {{ block.settings.padding }}px;
    text-align: center;
    position: relative;
  }

  .ai-welcome-popup-close-{{ ai_gen_id }} {
    position: absolute;
    top: 15px;
    right: 15px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    transition: opacity 0.2s ease;
    z-index: 1;
  }

  .ai-welcome-popup-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-welcome-popup-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-welcome-popup-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.accent_color }};
  }

  .ai-welcome-popup-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-welcome-popup-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    line-height: 1.5;
  }

  .ai-welcome-popup-discount-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.discount_text_color }};
    padding: 20px 40px;
    border-radius: {{ block.settings.discount_border_radius }}px;
    margin: {{ block.settings.spacing }}px 0;
    font-size: {{ block.settings.discount_size }}px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .ai-welcome-popup-button-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    padding: 16px 40px;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: background-color 0.3s ease, transform 0.2s ease;
    margin-top: {{ block.settings.spacing }}px;
  }

  .ai-welcome-popup-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-welcome-popup-terms-{{ ai_gen_id }} {
    font-size: {{ block.settings.terms_size }}px;
    color: {{ block.settings.text_muted_color }};
    margin-top: {{ block.settings.spacing }}px;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-welcome-popup-content-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-welcome-popup-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-welcome-popup-discount-{{ ai_gen_id }} {
      font-size: {{ block.settings.discount_size | times: 0.8 }}px;
      padding: 15px 30px;
    }

    .ai-welcome-popup-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<welcome-popup-{{ ai_gen_id }}
  class="ai-welcome-popup-{{ ai_gen_id }}"
  data-delay="{{ block.settings.delay }}"
  data-show-once="{{ block.settings.show_once }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-welcome-popup-overlay-{{ ai_gen_id }}"></div>
  <div class="ai-welcome-popup-container-{{ ai_gen_id }}">
    <div class="ai-welcome-popup-content-{{ ai_gen_id }}">
      <button
        class="ai-welcome-popup-close-{{ ai_gen_id }}"
        aria-label="Cerrar popup"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      {% if block.settings.show_icon %}
        <div class="ai-welcome-popup-icon-{{ ai_gen_id }}">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
          </svg>
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-welcome-popup-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-welcome-popup-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.discount_code != blank %}
        <div class="ai-welcome-popup-discount-{{ ai_gen_id }}">
          {{ block.settings.discount_code }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-welcome-popup-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      {% endif %}

      {% if block.settings.terms != blank %}
        <div class="ai-welcome-popup-terms-{{ ai_gen_id }}">
          {{ block.settings.terms }}
        </div>
      {% endif %}
    </div>
  </div>
</welcome-popup-{{ ai_gen_id }}>

<script>
  (function() {
    class WelcomePopup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.delay = parseInt(this.dataset.delay) || 0;
        this.showOnce = this.dataset.showOnce === 'true';
        this.cookieName = 'ai_welcome_popup_{{ ai_gen_id }}_shown';
      }

      connectedCallback() {
        this.overlay = this.querySelector('.ai-welcome-popup-overlay-{{ ai_gen_id }}');
        this.closeButton = this.querySelector('.ai-welcome-popup-close-{{ ai_gen_id }}');

        if (this.shouldShow()) {
          setTimeout(() => {
            this.show();
          }, this.delay);
        }

        this.setupEventListeners();
      }

      shouldShow() {
        if (!this.showOnce) {
          return true;
        }

        return !this.getCookie(this.cookieName);
      }

      show() {
        this.classList.add('active');
        document.body.style.overflow = 'hidden';

        if (this.showOnce) {
          this.setCookie(this.cookieName, 'true', 30);
        }
      }

      hide() {
        this.classList.remove('active');
        document.body.style.overflow = '';
      }

      setupEventListeners() {
        this.closeButton.addEventListener('click', () => {
          this.hide();
        });

        this.overlay.addEventListener('click', () => {
          this.hide();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.classList.contains('active')) {
            this.hide();
          }
        });
      }

      setCookie(name, value, days) {
        const date = new Date();
        date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
        const expires = 'expires=' + date.toUTCString();
        document.cookie = name + '=' + value + ';' + expires + ';path=/';
      }

      getCookie(name) {
        const nameEQ = name + '=';
        const ca = document.cookie.split(';');
        for (let i = 0; i < ca.length; i++) {
          let c = ca[i];
          while (c.charAt(0) === ' ') c = c.substring(1, c.length);
          if (c.indexOf(nameEQ) === 0) return c.substring(nameEQ.length, c.length);
        }
        return null;
      }
    }

    customElements.define('welcome-popup-{{ ai_gen_id }}', WelcomePopup{{ ai_gen_id }});
  })();
</script>

